#!/usr/bin/env bash
# Install alerter (macOS notification CLI) from the vjeantet/alerter GitHub
# release. Not in core brew; the finbar-lahart/alerter tap does not exist;
# vendoring the binary in git is heavy → download + place + de-quarantine.
#
# Bumping VERSION below changes this script's content hash, so chezmoi
# run_onchange re-runs and refreshes the binary on the next apply.
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
VERSION="26.5"
DEST="/opt/homebrew/bin/alerter"

if [ -x "$DEST" ] && [ "$("$DEST" --version 2>/dev/null | head -1)" = "$VERSION" ]; then
  exit 0
fi

URL="https://github.com/vjeantet/alerter/releases/download/v${VERSION}/alerter-${VERSION}.zip"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

echo "Downloading alerter v${VERSION} from ${URL} …"
curl -fsSL -o "$TMP/alerter.zip" "$URL"
( cd "$TMP" && unzip -oq alerter.zip )

BIN="$(find "$TMP" -type f -name alerter | head -1)"
[ -n "$BIN" ] || { echo "alerter binary not found in zip" >&2; exit 1; }

install -m 0755 "$BIN" "$DEST"
xattr -dr com.apple.quarantine "$DEST" 2>/dev/null || true

echo "Installed alerter v${VERSION} → $DEST"
{{ end -}}
