#!/usr/bin/env bash
set -euo pipefail

vault="{{ index . "onePasswordVault" | default "Dotfiles" }}"
secret_dir="${DOTFILES_SECRET_DIR:-$HOME/.local/state/dotfiles/secrets}"

# Chezmoi may run this script with a minimal PATH; Linuxbrew often is not included.
brew_bins=(
  /home/linuxbrew/.linuxbrew/bin
  "${HOME}/.linuxbrew/bin"
  /opt/homebrew/bin
  /usr/local/bin
  "${HOME}/.local/bin"
)
for d in "${brew_bins[@]}"; do
  if [[ -d "$d" ]]; then
    PATH="$d:$PATH"
  fi
done
export PATH

if ! command -v op >/dev/null 2>&1; then
  echo "Skipping private file restore: 1Password CLI (op) not on PATH."
  echo "Install on Linuxbrew: brew install 1password-cli"
  echo "Then run again: sync"
  exit 0
fi

# When chezmoi runs over ssh without a login shell, nushell's env.nu hasn't
# fired to set OP_SERVICE_ACCOUNT_TOKEN. Source the same file that env.nu reads
# so headless `chezmoi update` on the lab can authenticate.
op_sa_file="${HOME}/.config/op/sa-token"
if [[ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" && -f "$op_sa_file" ]]; then
  OP_SERVICE_ACCOUNT_TOKEN=$(tr -d '[:space:]' < "$op_sa_file")
  export OP_SERVICE_ACCOUNT_TOKEN
fi

# Never block chezmoi on 1Password first-run prompts (e.g. "add an account now?").
# Those come from commands like `op vault get` when no account exists yet.
run_op() {
  if command -v timeout >/dev/null 2>&1; then
    timeout 8 "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout 8 "$@"
  else
    "$@"
  fi
}

have_op_accounts() {
  local out
  out="$(run_op op account list --format=json 2>/dev/null || true)"
  echo "$out" | python3 -c '
import json, sys
raw = sys.stdin.read().strip()
if not raw:
    raise SystemExit(1)
data = json.loads(raw)
sys.exit(0 if isinstance(data, list) and len(data) > 0 else 1)
'
}

prompt_for_service_account_token() {
  if [[ ! -t 0 ]]; then
    return 1
  fi

  echo "No signed-in 1Password session is available."
  echo "Paste OP_SERVICE_ACCOUNT_TOKEN to restore private files, or leave empty to skip."
  printf "OP_SERVICE_ACCOUNT_TOKEN: "
  local token
  IFS= read -rs token || true
  printf "\n"

  if [[ -z "$token" ]]; then
    return 1
  fi

  export OP_SERVICE_ACCOUNT_TOKEN="$token"
}

ensure_op_signed_in() {
  if run_op op whoami >/dev/null 2>&1; then
    return 0
  fi

  if [[ -n "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]]; then
    echo "OP_SERVICE_ACCOUNT_TOKEN is set, but op whoami failed."
    return 1
  fi

  if have_op_accounts; then
    echo "1Password CLI is not signed in; starting op signin for this sync."
    if [[ -t 0 ]]; then
      # The exported OP_SESSION_* variable only needs to live for this script.
      if eval "$(op signin -f)"; then
        run_op op whoami >/dev/null 2>&1 && return 0
      fi
    else
      echo "Cannot run interactive op signin without a TTY."
    fi
  fi

  if prompt_for_service_account_token && run_op op whoami >/dev/null 2>&1; then
    return 0
  fi

  echo "Skipping private file restore: 1Password is not authenticated."
  echo "Run: op account add"
  echo "Then run: sync"
  echo "Headless machines can export OP_SERVICE_ACCOUNT_TOKEN before sync."
  return 1
}

if ! ensure_op_signed_in; then
  exit 0
fi

if ! run_op op vault get "$vault" >/dev/null 2>&1; then
  echo "Skipping private file restore: 1Password vault '$vault' is not available (or op timed out)."
  exit 0
fi

mkdir -p "$secret_dir"
chmod 700 "$secret_dir"

restore_document() {
  local item="$1"
  local out_file="$2"

  if run_op op document get "$item" \
    --vault "$vault" \
    --out-file "$out_file" \
    --file-mode 0600 \
    --force \
    >/dev/null 2>&1; then
    chmod 600 "$out_file"
    echo "Restored $item."
  else
    echo "Skipping $item: document not found in 1Password vault '$vault'."
  fi
}

restore_password_field() {
  local item="$1"
  local out_file="$2"

  if run_op op read \
    --out-file "$out_file" \
    --file-mode 0600 \
    --force \
    "op://$vault/$item/password" \
    >/dev/null 2>&1; then
    chmod 600 "$out_file"
    echo "Restored $item."
  else
    echo "Skipping $item: item/password field not found in 1Password vault '$vault'."
  fi
}

restore_document "WEEKLY_PROJECT_UPDATE_SCRIPT" "$secret_dir/weekly-slack-board-update.nu"
restore_password_field "GITLEAKS_PRIVATE_CONFIG" "$secret_dir/gitleaks-private.toml"

# Work identifiers (org/team/roster/Slack IDs) live OUTSIDE the public repo.
# Three consumers, three formats — all backed by 1Password documents:
#   WORK_CONTEXT_MD    → prose/tables read at runtime by skills (daily-brief, g-pr-bump, ...)
#   WORK_ENV           → env file sourced by bin/* scripts and work-env.nu
#   DOTFILES_WORK_DATA → chezmoi template data (.chezmoidata/private-work.toml, gitignored)
restore_document "WORK_CONTEXT_MD" "$secret_dir/work-context.md"
restore_document "WORK_ENV" "$secret_dir/work.env"
restore_document "DOTFILES_WORK_DATA" "{{ .chezmoi.sourceDir }}/.chezmoidata/private-work.toml"

# Work-scoped skills whose NAMES are private (client/product names) — read by
# run_onchange_after_30 to place them into the work monorepo's .claude/skills
# only (never the public repo, never global).
restore_document "WORK_SCOPE_SKILLS" "$secret_dir/work-scope-skills.txt"

# Private skills/rules overlay: work-specific skills and rules that must not sit
# in the public repo. One tar bundle (agent-skills/... + agent-rules/... inside),
# extracted into the secrets dir; synced into ~/.claude + ~/.cursor by scripts
# 30/31 AFTER the public rsync.
if restore_document "PRIVATE_AGENT_ASSETS_TAR" "$secret_dir/private-agent-assets.tar"; then
  if tar -tf "$secret_dir/private-agent-assets.tar" >/dev/null 2>&1; then
    tar -xf "$secret_dir/private-agent-assets.tar" -C "$secret_dir"
    echo "Extracted private agent assets overlay."
  fi
fi

# Stream Deck Office page → Homey Athom cloud API (https://<HOMEY_ID>.connect.athom.com).
# bin/homey-cap reads the PAT from ~/.config/streamdeck/homey-token (0600) and the
# Homey ID (connect subdomain) from ~/.config/streamdeck/homey-id. Both live in
# 1Password items HOMEY_TOKEN / HOMEY_ID (password field), never in the repo.
mkdir -p "$HOME/.config/streamdeck"
restore_password_field "HOMEY_TOKEN" "$HOME/.config/streamdeck/homey-token"
restore_password_field "HOMEY_ID" "$HOME/.config/streamdeck/homey-id"

# tmux-weather home location: two custom fields (lat, lon) on a 1P item.
# Rendered as a sourceable env file consumed by bin/tmux-weather.
restore_env_pair() {
  local item="$1"
  local out_file="$2"
  local field_a="$3"
  local field_b="$4"

  local val_a val_b
  val_a="$(run_op op read "op://$vault/$item/$field_a" 2>/dev/null || true)"
  val_b="$(run_op op read "op://$vault/$item/$field_b" 2>/dev/null || true)"

  if [[ -z "$val_a" || -z "$val_b" ]]; then
    echo "Skipping $item: $field_a/$field_b not found in 1Password vault '$vault'."
    return
  fi

  mkdir -p "$(dirname "$out_file")"
  {
    printf '%s=%s\n' "$(echo "$field_a" | tr '[:lower:]' '[:upper:]')" "$val_a"
    printf '%s=%s\n' "$(echo "$field_b" | tr '[:lower:]' '[:upper:]')" "$val_b"
  } > "$out_file"
  chmod 600 "$out_file"
  echo "Restored $item → $out_file."
}

restore_env_pair "TMUX_WEATHER_HOME" "$secret_dir/tmux-weather-home.env" "lat" "lon"

# Jam SQL Studio MCP bearer token (1P item JAM_SQL, password field). The same
# token is baked into the Claude user-scope MCP config by agent-mcp sync;
# this env file is for scripts that talk to the Jam MCP directly.
jam_token="$(run_op op read "op://$vault/JAM_SQL/password" 2>/dev/null || true)"
if [[ -n "$jam_token" ]]; then
  printf 'JAM_SQL_TOKEN=%s\n' "$jam_token" > "$secret_dir/jamsql.env"
  chmod 600 "$secret_dir/jamsql.env"
  echo "Restored JAM_SQL → $secret_dir/jamsql.env."
else
  echo "Skipping JAM_SQL: not found in 1Password vault '$vault'."
fi

mkdir -p "$secret_dir/statuses"
chmod 700 "$secret_dir/statuses"

# GPG signing key: import from 1Password once. Idempotent — if the fingerprint
# is already in the local keyring, skip. Same key on every machine so the
# `Verified` badge on GitHub stays consistent across workstation + lab.
gpg_fingerprint="F38BCBF8BCEB902DD0F002F4964AFA51FDB3DDF8"
if command -v gpg >/dev/null 2>&1; then
  mkdir -p "$HOME/.gnupg"
  chmod 700 "$HOME/.gnupg"

  if gpg --list-secret-keys "$gpg_fingerprint" >/dev/null 2>&1; then
    echo "GPG key $gpg_fingerprint already imported."
  else
    gpg_tmp="$(mktemp -d)"
    chmod 700 "$gpg_tmp"
    trap 'rm -rf "$gpg_tmp"' EXIT

    if restore_document "GPG_SECRET_KEY" "$gpg_tmp/secret.asc" \
       && restore_document "GPG_PUBLIC_KEY" "$gpg_tmp/public.asc" \
       && restore_document "GPG_OWNERTRUST" "$gpg_tmp/ownertrust.txt"; then
      gpg --batch --import "$gpg_tmp/public.asc" 2>/dev/null || true
      gpg --batch --import "$gpg_tmp/secret.asc" 2>/dev/null || true
      gpg --import-ownertrust "$gpg_tmp/ownertrust.txt" 2>/dev/null || true
      echo "Imported GPG key $gpg_fingerprint."
    else
      echo "Skipping GPG import: one or more documents missing in vault '$vault'."
    fi

    rm -rf "$gpg_tmp"
    trap - EXIT
  fi
fi
