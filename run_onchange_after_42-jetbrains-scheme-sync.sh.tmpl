#!/usr/bin/env bash
{{- if eq .chezmoi.os "darwin" }}
# Sync Mocha Neon ICLS color scheme into every JetBrains IDE's colors/ dir
# (DataGrip / IntelliJ / WebStorm / etc). After this hook lands the scheme,
# the user still has to switch to it once via Settings → Editor → Color Scheme.
#
# fingerprint: {{ output "bash" "-c" (printf "cd %q && find dot_config/jetbrains -type f -name '*.icls' -print0 2>/dev/null | sort -z | xargs -0 sha256sum 2>/dev/null | sha256sum | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -eu

SRC_DIR="$HOME/.config/jetbrains"
JB_ROOT="$HOME/Library/Application Support/JetBrains"

if [ ! -d "$SRC_DIR" ]; then
  echo "jetbrains-scheme-sync: $SRC_DIR missing — skipping."
  exit 0
fi
if [ ! -d "$JB_ROOT" ]; then
  echo "jetbrains-scheme-sync: no JetBrains installs — skipping."
  exit 0
fi

found_any=0
# Sync to every product+version dir (DataGrip2024.1, IntelliJIdea2025.1, etc.)
for prod in "$JB_ROOT"/*/; do
  [ -d "$prod" ] || continue
  # Skip non-product dirs (consentOptions, crl, bl, etc.) — only sync into
  # dirs whose name contains a YYYY.N version pattern.
  if ! basename "$prod" | grep -qE '20[0-9]{2}\.[0-9]'; then
    continue
  fi
  mkdir -p "$prod/colors"
  for icls in "$SRC_DIR"/*.icls; do
    [ -f "$icls" ] || continue
    cp -f "$icls" "$prod/colors/$(basename "$icls")"
    echo "jetbrains-scheme-sync: $(basename "$icls") → $prod/colors/"
    found_any=1
  done
done

if [ "$found_any" -eq 0 ]; then
  echo "jetbrains-scheme-sync: no IDE version dirs matched — skipping."
fi
{{- end }}
