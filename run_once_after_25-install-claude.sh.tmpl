#!/usr/bin/env bash
# Install Claude Code CLI if missing.
# Uses the official native installer (https://claude.ai/install.sh) on every OS —
# the native build auto-updates itself. Brew cask was dropped 2026-06-10 because
# it lags 2+ weeks behind official releases (was stuck on 2.1.153 while latest
# was 2.1.170).
set -euo pipefail

if command -v claude >/dev/null 2>&1; then
  echo "install-claude: claude already on PATH — skipping."
  exit 0
fi

echo "install-claude: installing via official native installer."
curl -fsSL https://claude.ai/install.sh | bash
