#!/usr/bin/env bash
# Sync agent-skills/ -> BOTH ~/.cursor/skills and ~/.claude/skills via rsync.
# Re-runs whenever the fingerprint below changes (i.e. anything in agent-skills/).
#
# fingerprint: {{ output "bash" "-c" (printf "cd %q && find agent-skills -type f -print0 2>/dev/null | sort -z | xargs -0 sha256sum 2>/dev/null | sha256sum | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -e

SOURCE="{{ .chezmoi.sourceDir }}/agent-skills"

if [[ ! -d "$SOURCE" ]]; then
  echo "agent-skills sync: source $SOURCE missing — skipping."
  exit 0
fi

for target in "${HOME}/.cursor/skills" "${HOME}/.claude/skills"; do
  mkdir -p "$target"
  rsync -a --delete \
    --exclude '.DS_Store' \
    "${SOURCE}/" "${target}/"
done

echo "agent-skills sync: $(ls -1d "${HOME}/.cursor/skills"/*/ 2>/dev/null | wc -l | tr -d ' ') skill(s) in each target."
