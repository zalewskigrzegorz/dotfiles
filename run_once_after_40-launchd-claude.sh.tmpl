#!/usr/bin/env bash
{{- if eq .chezmoi.os "darwin" }}
# Idempotent install + load of LaunchAgents:
#   - com.greg.aerospace-watchdog (restarts AeroSpace.app if it dies — chicken
#                                  and egg fix for `Leader+X` rebind)
#   - com.greg.temp-watch (polls smctemp every 20s, alerter notifications when
#                          CPU crosses 85°C threshold and again when it cools
#                          back below 75°C — "odpal podstawkę" reminder)
#   - com.greg.slack-watch (polls Slack Helper (Renderer) %CPU every 60s;
#                          restarts Slack when a renderer hangs >120% for 3
#                          consecutive checks — see bin/slack-renderer-watchdog)
#   - com.greg.sketchybar-watch (every 15s; restarts sketchybar when it dies or
#                          hangs — happens on display reconfig / resolution
#                          change — see bin/sketchybar-watchdog)
#   - com.greg.sketchybar-display (resident KeepAlive; listens for screen-param
#                          changes and forces `sketchybar --reload` to fix the
#                          render-freeze where the bar survives but stops drawing
#                          — see bin/sketchybar-display-listener)
# Legacy labels (claude-watcher / claude-idle-timer) are explicitly torn down
# below — they fed the now-removed sketchybar claude_sessions widget.
# `run_once_*` per chezmoi semantics — re-runs only when this script's content
# changes. To force a re-bootstrap (e.g. after editing the plists), bump the
# version stamp in the comment below.
#
# Version: 2026-06-26.3
set -eu

SRC_DIR="${HOME}/.config/launchd"
DST_DIR="${HOME}/Library/LaunchAgents"
mkdir -p "$DST_DIR"

# Tear down legacy claude-* agents if they were installed on this machine.
for legacy in com.greg.claude-watcher com.greg.claude-idle-timer; do
  launchctl bootout "gui/$(id -u)/${legacy}" 2>/dev/null || true
  rm -f "${DST_DIR}/${legacy}.plist"
done

for label in com.greg.aerospace-watchdog com.greg.temp-watch com.greg.slack-watch com.greg.sketchybar-watch com.greg.sketchybar-display; do
  src="${SRC_DIR}/${label}.plist"
  dst="${DST_DIR}/${label}.plist"
  if [[ ! -f "$src" ]]; then
    echo "[skip] $src not found"
    continue
  fi
  cp -f "$src" "$dst"
  # Unload if already loaded — bootout is safe even if the label isn't there.
  launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "$dst"
  echo "[ok] $label bootstrapped"
done
{{- end }}
