[core]
    pager = delta
    # fsmonitor: a per-repo background daemon watches FSEvents so `git status`
    # checks only changed paths instead of rescanning the whole tree. With many
    # concurrent Claude Code sessions polling `git status --untracked-files=all`
    # in worktrees, the full rescans pegged git CPU and flooded the Kandji ESF
    # endpoint-security extension with file-stat events. fsmonitor + the
    # untracked cache cut both. (git 2.54; added 2026-06-26.)
    fsmonitor = true
    untrackedCache = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true
    line-numbers = true
    # TODO: pin a Mocha Neon bat theme once it's built. Default (no syntax-theme)
    # falls back to bat's default — better than Dracula (banned by Mocha Neon rule).

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[difftool]
    prompt = false

[user]
    email = grzegorz.zalewski@redocly.com
    name = Grzegorz Zalewski
    signingKey = F38BCBF8BCEB902DD0F002F4964AFA51FDB3DDF8

[gpg]
{{- if eq .chezmoi.os "darwin" }}
    program = /opt/homebrew/bin/gpg
{{- else }}
    program = /usr/bin/gpg
{{- end }}
    format = openpgp

[commit]
    gpgSign = true

[tag]
    forceSignAnnotated = true

[gpg "ssh"]
    program = ssh-keygen
    allowedSignersFile =

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current

{{- $gh := "/usr/bin/gh" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $gh = "/opt/homebrew/bin/gh" -}}
{{- end }}
[credential "https://github.com"]
	helper = 
	helper = !{{ $gh }} auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !{{ $gh }} auth git-credential
