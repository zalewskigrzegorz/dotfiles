[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true
    line-numbers = true
    # TODO: pin a Mocha Neon bat theme once it's built. Default (no syntax-theme)
    # falls back to bat's default — better than Dracula (banned by Mocha Neon rule).

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    tool = hunk

[difftool]
    prompt = false

[difftool "hunk"]
    cmd = hunk difftool "$LOCAL" "$REMOTE"

[alias]
    # hunk = review-first TUI for agent changesets (delta stays the pager).
    # `git review` / `git rv` open the working-tree diff in watch mode so the
    # view auto-reloads as an agent edits. Pass a target to review a ref/branch.
    review = !hunk diff --watch
    rv = !hunk diff --watch

[user]
    email = grzegorz.zalewski@REDACTED_ORG.com
    name = Grzegorz Zalewski
    signingKey = F38BCBF8BCEB902DD0F002F4964AFA51FDB3DDF8

[gpg]
{{- if eq .chezmoi.os "darwin" }}
    program = /opt/homebrew/bin/gpg
{{- else }}
    program = /usr/bin/gpg
{{- end }}
    format = openpgp

[commit]
    gpgSign = true

[tag]
    forceSignAnnotated = true

[gpg "ssh"]
    program = ssh-keygen
    allowedSignersFile =

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current

{{- $gh := "/usr/bin/gh" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $gh = "/opt/homebrew/bin/gh" -}}
{{- end }}
[credential "https://github.com"]
	helper = 
	helper = !{{ $gh }} auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !{{ $gh }} auth git-credential
