[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true
    line-numbers = true
    # TODO: pin a Mocha Neon bat theme once it's built. Default (no syntax-theme)
    # falls back to bat's default — better than Dracula (banned by Mocha Neon rule).

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[user]
    email = grzegorz.zalewski@REDACTED_ORG.com
    name = Grzegorz Zalewski
    signingKey = F38BCBF8BCEB902DD0F002F4964AFA51FDB3DDF8

[gpg]
{{- if eq .chezmoi.os "darwin" }}
    program = /opt/homebrew/bin/gpg
{{- else }}
    program = /usr/bin/gpg
{{- end }}
    format = openpgp

[commit]
    gpgSign = true

[tag]
    forceSignAnnotated = true

[gpg "ssh"]
    program = ssh-keygen
    allowedSignersFile =

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
