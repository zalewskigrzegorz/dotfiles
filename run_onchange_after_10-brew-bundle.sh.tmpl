#!/usr/bin/env bash
# Re-runs whenever ~/.Brewfile changes (chezmoi hashes the rendered script).
# Brewfile hash: {{ include "dot_Brewfile.tmpl" | sha256sum }}
set -euo pipefail

export HOMEBREW_NO_ENV_HINTS=1

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "brew not found; skipping brew bundle" >&2
  exit 0
fi

if [[ ! -f "$HOME/.Brewfile" ]]; then
  echo "$HOME/.Brewfile not found; skipping brew bundle" >&2
  exit 0
fi

brew bundle --global
