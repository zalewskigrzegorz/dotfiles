#!/usr/bin/env bash
# Sync agent-mcp/mcp-servers.json (rendered) into Claude Code user-scope MCP.
# (Cursor reads ~/.cursor/mcp.json directly — handled by dot_cursor/mcp.json.tmpl.)
#
# Re-runs whenever the rendered MCP config changes.
# fingerprint: {{ includeTemplate "agent-mcp/mcp-servers.json.tmpl" . | sha256sum }}

set -e

# chezmoi runs hooks with a minimal PATH. Extend it so the lab's
# ~/.local/bin/claude (npm-style install) and brew installs on either
# platform are discoverable before the `command -v claude` check.
for d in \
  "/opt/homebrew/bin" \
  "/home/linuxbrew/.linuxbrew/bin" \
  "${HOME}/.local/bin" \
  "${HOME}/.local/share/claude/bin" \
  "${HOME}/node_modules/.bin" \
; do
  [[ -d "$d" ]] && PATH="$d:$PATH"
done
export PATH

if ! command -v claude &>/dev/null; then
  echo "agent-mcp sync: claude CLI not on PATH — skipping."
  exit 0
fi

tmp="$(mktemp -t agent-mcp.XXXXXX.json)"
trap 'rm -f "$tmp"' EXIT

cat >"$tmp" <<'__MCP_JSON__'
{{ includeTemplate "agent-mcp/mcp-servers.json.tmpl" . }}
__MCP_JSON__

python3 - "$tmp" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

cfg = json.loads(Path(sys.argv[1]).read_text())
servers = cfg.get("mcpServers", {})
desired = set(servers.keys())

# 1) Drop user-scoped servers that the template no longer declares. Without
#    this step, removing an entry from mcp-servers.json.tmpl leaves the old
#    server hanging in ~/.claude.json forever (bit us 2026-05-24 when
#    MCP_DOCKER + chrome-devtools survived their removal from the template).
claude_home = Path.home() / ".claude.json"
if claude_home.exists():
    try:
        live = json.loads(claude_home.read_text())
        current = set((live.get("mcpServers") or {}).keys())
    except json.JSONDecodeError:
        current = set()
    for orphan in sorted(current - desired):
        subprocess.run(["claude", "mcp", "remove", "--scope", "user", orphan],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print(f"  - {orphan}")

# 2) Upsert every desired server (remove-then-add is idempotent).
for name, spec in servers.items():
    subprocess.run(["claude", "mcp", "remove", "--scope", "user", name],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    cmd = ["claude", "mcp", "add", "--scope", "user"]
    if "url" in spec:
        # Pass through HTTP headers (`--header "Header: Value"`) for HTTP/SSE
        # servers that auth via static tokens (e.g. n8n-mcp Bearer). Without
        # this, `claude mcp add` registers the URL but drops auth → server
        # shows "Needs authentication" forever.
        # Argument order matters: `--transport <t>`, then positional name+url,
        # THEN `--header` flags (variadic). Headers before positionals make
        # `claude mcp add` swallow the name as another header value.
        cmd += ["--transport", spec.get("type", "http"), name, spec["url"]]
        for k, v in (spec.get("headers") or {}).items():
            cmd += ["--header", f"{k}: {v}"]
    else:
        env_pairs = [f"{k}={v}" for k, v in (spec.get("env") or {}).items()]
        if env_pairs:
            # `-e` is variadic; pass all pairs in one flag, then `--` ends the
            # env list so the next positional is the server name.
            cmd += ["-e", *env_pairs, "--"]
        else:
            cmd += ["--"]
        cmd += [name, spec["command"], *spec.get("args", [])]

    try:
        subprocess.run(cmd, check=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
        print(f"  + {name}")
    except subprocess.CalledProcessError as e:
        sys.stderr.write(f"  ! {name}: {e.stderr.decode().strip()}\n")
PY

echo "agent-mcp sync: done."
