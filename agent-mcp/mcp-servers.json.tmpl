{
  "mcpServers": {
    "draw": {
      "type": "http",
      "url": "https://mcp.lab/excalidraw/mcp"
    },
    "Homey": {
      "type": "http",
      "url": "https://mcp.lab/homey/mcp"
    },
    "nushell": {
      "command": "{{ .chezmoi.homeDir }}/.cargo/bin/mcp-server-nu",
      "args": [
        "--nu-config",
        "{{ .chezmoi.homeDir }}/.config/nushell/config.nu",
        "--nu-env-config",
        "{{ .chezmoi.homeDir }}/.config/nushell/env.nu"
      ]
    },
    "console-ninja": {
      "command": "node",
      "args": ["{{ .chezmoi.homeDir }}/.console-ninja/mcp/"]
    },
    "wallaby": {
      "command": "node",
      "args": ["{{ .chezmoi.homeDir }}/.wallaby/mcp/"]
    },
    {{/* Disabled while testing agent-browser as the browser skill. Re-enable by removing the surrounding chezmoi comment.
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    */}}
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"]
    },
    "mempalace": {
      "command": "mempalace-mcp"
    },
    "grafana": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "--enabled-tools",
        "clickhouse,prometheus,datasource,loki,elasticsearch",
        "-t",
        "stdio"
      ],
      "env": {
        "GRAFANA_URL": "https://grafana.REDACTED_ORG.com",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": {{ onepasswordRead (printf "op://%s/GRAFANA_SERVICE_ACCOUNT_TOKEN/password" (index . "onePasswordVault" | default "Dotfiles")) | quote }}
      }
    },
    "grafana-dashboards": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "--enabled-tools",
        "search,dashboard,navigation",
        "-t",
        "stdio"
      ],
      "env": {
        "GRAFANA_URL": "https://grafana.REDACTED_ORG.com",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": {{ onepasswordRead (printf "op://%s/GRAFANA_SERVICE_ACCOUNT_TOKEN/password" (index . "onePasswordVault" | default "Dotfiles")) | quote }}
      }
    },
    "awslabs-cloudwatch-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "--interactive",
        "-v",
        "{{ .chezmoi.homeDir }}/.aws:/app/.aws",
        "-e",
        "AWS_PROFILE=REDACTED_ORG-prod",
        "mcp/cloudwatch-mcp-server:latest"
      ]
    }
  }
}
