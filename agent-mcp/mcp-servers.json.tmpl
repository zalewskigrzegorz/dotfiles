{
  "mcpServers": {
    "draw": {
      "type": "http",
      "url": "https://mcp.lab/excalidraw/mcp"
    },
    "Homey": {
      "type": "http",
      "url": "https://mcp.lab/homey/mcp"
    },
    "nushell": {
      "command": "{{ .chezmoi.homeDir }}/.cargo/bin/mcp-server-nu",
      "args": [
        "--nu-config",
        "{{ .chezmoi.homeDir }}/.config/nushell/config.nu",
        "--nu-env-config",
        "{{ .chezmoi.homeDir }}/.config/nushell/env.nu"
      ]
    },
    "console-ninja": {
      "command": "node",
      "args": ["{{ .chezmoi.homeDir }}/.console-ninja/mcp/"]
    },
    "wallaby": {
      "command": "node",
      "args": ["{{ .chezmoi.homeDir }}/.wallaby/mcp/"]
    },
    {{/* Disabled while testing agent-browser as the browser skill. Re-enable by removing the surrounding chezmoi comment. Kept around because agent-browser is great for navigation/scraping but writing real Playwright specs may want this back.
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    */}}
    {{/* Docker MCP Toolkit gateway DROPPED 2026-05-24. Hypothesis "Docker = less context" turned out false (the gateway loads all 48 tools into Claude's tool registry the same as N separate MCPs would). Browser automation goes through the agent-browser skill instead. To re-enable: uncomment and `docker mcp gateway run` (Docker Desktop must be on).
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"]
    },
    */}}
    {{/* chrome-devtools DROPPED 2026-05-24. Required Node >= 20.19, mise had 20.18, so it failed to connect. agent-browser covers the same use cases faster. Re-enable after bumping Node + only if agent-browser turns out to be missing something concrete.
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    */}}
    "mempalace": {
      "command": "mempalace-mcp"
    },
    "jetbrains": {
      "command": "npx",
      "args": ["-y", "@jetbrains/mcp-proxy"]
    },
    {{/* grafana + grafana-dashboards + cloudwatch are now project-scoped to the
         work monorepo's own team-tracked .mcp.json, so they no longer load in
         every repo via the global user scope. */}}
    "n8n-mcp": {
      "type": "http",
      "url": "http://n8n.lab/mcp-server/http",
      "headers": {
        "Authorization": {{ if lookPath "op" }}{{ printf "Bearer %s" (onepasswordRead (printf "op://%s/N8N_API_KEY/password" (index . "onePasswordVault" | default "Dotfiles"))) | quote }}{{ else }}"Bearer "{{ end }}
      }
    },
    {{/* Jam SQL Studio — AI-first DB client (macOS app, no brew cask; installed
         from downloads.jamsql.com). Local MCP server: read-only, maxRows 1000,
         query timeout 30s; port is persisted via preferredPort in the app's
         mcp-server-config.json. Token lives in 1P (Dotfiles/JAM_SQL). Queries
         run through the app so Greg sees them + results in the GUI. */}}
    "jamsql": {
      "type": "http",
      "url": "http://127.0.0.1:14507/mcp",
      "headers": {
        "Authorization": {{ if lookPath "op" }}{{ printf "Bearer %s" (onepasswordRead (printf "op://%s/JAM_SQL/password" (index . "onePasswordVault" | default "Dotfiles"))) | quote }}{{ else }}"Bearer "{{ end }}
      }
    },
    "hindsight": {
      "type": "http",
      "url": "http://192.168.50.10:8888/mcp/greg/"
    },
    {{/* Agent-Native Plan connector — backs the visual-plan / visual-recap /
         visualize-repo skills (BuilderIO/skills). Hosted mode: plan/recap MDX is
         published to plan.agent-native.com. OAuth is per-client — authenticate
         once via `/mcp` → plan → Authenticate (browser). Until then it shows
         "Failed to connect". local-files mode needs no auth. */}}
    "plan": {
      "type": "http",
      "url": "https://plan.agent-native.com/mcp"
    }
  }
}
