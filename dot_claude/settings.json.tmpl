{
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "CLAUDE_WEEKLY_RESET": "2026-05-17T04:00",
    "CLAUDE_SESSION_TOKEN_LIMIT": "200000000",
    "CLAUDE_WEEKLY_TOKEN_LIMIT": "1100000000"
  },
  "permissions": {
    "allow": [
      "Read(/{{ .chezmoi.homeDir }}/**)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git rev-parse*)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(chezmoi diff*)",
      "Bash(chezmoi managed*)",
      "Bash(chezmoi source-path*)",
      "Bash(chezmoi data*)",
      "Bash(chezmoi execute-template*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh api*)",
      "Bash(brew info*)",
      "Bash(brew list*)",
      "Bash(claude mcp list)",
      "Bash(mempalace *)",
      "Bash(mempalace-mcp *)",
      "Bash(ssh lab:*)",
      "Bash(ssh lab-via-ip:*)",

      "Edit(/{{ .chezmoi.homeDir }}/Code/**)",
      "Write(/{{ .chezmoi.homeDir }}/Code/**)",
      "Read(//tmp/**)",
      "WebFetch",
      "WebSearch",
      "Skill(agent-browser)",
      "Bash(agent-browser:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh search:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git merge --no-ff:*)",
      "Bash(git rebase:*)",
      "Bash(git tag:*)",
      "Bash(git worktree list)",

      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(yarn test:*)",
      "Bash(yarn run:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(make:*)",

      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(chezmoi apply:*)",
      "Bash(chezmoi add:*)",
      "Bash(chezmoi re-add:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/protect-files.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-build-artifacts.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/scan-secrets.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/mcp-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/bazgroly-autostage.sh",
            "timeout": 30000
          }
        ]
      }
    ]{{ if ne .profile "homelab" }},
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook session-start --harness claude-code"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/bazgroly-autopush-on-start.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook stop --harness claude-code"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/stop.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/bazgroly-autopush-on-stop.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook precompact --harness claude-code"
          }
        ]
      }
    ]
    {{- end }}
  },
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.homeDir }}/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "pl-en-short",
  "theme": "custom:dracula-pro",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
