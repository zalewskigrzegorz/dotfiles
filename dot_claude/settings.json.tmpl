{
  "theme": "custom:dracula-pro",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "outputStyle": "bilingual-concise",
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.homeDir }}/.claude/statusline.sh"
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "CLAUDE_WEEKLY_RESET": "2026-05-17T04:00"
  },
  "permissions": {
    "allow": [
      "Read(/{{ .chezmoi.homeDir }}/**)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git rev-parse*)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(chezmoi diff*)",
      "Bash(chezmoi managed*)",
      "Bash(chezmoi source-path*)",
      "Bash(chezmoi data*)",
      "Bash(chezmoi execute-template*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh api*)",
      "Bash(brew info*)",
      "Bash(brew list*)",
      "Bash(claude mcp list)",
      "Bash(mempalace *)",
      "Bash(mempalace-mcp *)"
    ]
  },
  {{- /* Marketplaces + enabled plugins are declared in agent-plugins/plugins.json.tmpl. */ -}}
  {{- $pluginData := includeTemplate "agent-plugins/plugins.json.tmpl" . | fromJson -}}
  {{- $mps := dict -}}
  {{- range $name, $src := $pluginData.marketplaces -}}
    {{- $_ := set $mps $name (dict "source" $src) -}}
  {{- end }}
  "extraKnownMarketplaces": {{ $mps | toJson }},
  {{- $enabled := dict -}}
  {{- range $p := $pluginData.plugins -}}
    {{- $_ := set $enabled $p true -}}
  {{- end }}
  "enabledPlugins": {{ $enabled | toJson }},
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook session-start --harness claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook stop --harness claude-code"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook precompact --harness claude-code"
          }
        ]
      }
    ]
  }
}
