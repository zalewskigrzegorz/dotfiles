#!/usr/bin/env bash
# Install + (re)load the com.greg.pr-watch LaunchAgent: polls GitHub every 3 min
# via bin/pr-watch and pushes the SketchyBar pr_watch chip. Mac-only. Self-
# contained (emits the plist inline) so `chezmoi apply` reproduces it on a fresh
# machine — mirrors run_onchange_after_20's approach.
#
# Bump this version comment to force re-run when the plist/interval changes.
# Version: 2026-06-24.1
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
plist_dir="$HOME/Library/LaunchAgents"
plist_file="$plist_dir/com.greg.pr-watch.plist"
mkdir -p "$plist_dir"

cat > "$plist_file" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.greg.pr-watch</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ .chezmoi.homeDir }}/Code/dotfiles/bin/pr-watch</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>180</integer>
  <key>StandardOutPath</key>
  <string>/tmp/com.greg.pr-watch.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/com.greg.pr-watch.err</string>
</dict>
</plist>
PLIST

if launchctl list | grep -q "com.greg.pr-watch"; then
  launchctl unload "$plist_file" || true
fi
launchctl load "$plist_file"
echo "[ok] com.greg.pr-watch loaded (poll every 180s)"
{{ else -}}
exit 0
{{ end -}}
