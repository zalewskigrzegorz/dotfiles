# 1Password Service Account token is NOT exported into interactive Mac shells.
# Reason: when OP_SERVICE_ACCOUNT_TOKEN is set, `op` ignores the desktop app /
# Touch ID session entirely (service-account auth has hard priority), so any
# casual `op item get` / `op item create` runs against the read-only service
# account and fails for writes. Greg's interactive use → personal account.
#
# The token is still loaded transparently at chezmoi-apply time by `bin/sync`
# (this dotfiles repo) — that wrapper sets the env var only for chezmoi's
# subprocess lifetime, so template renders (`onepasswordRead`) still work.
#
# Lab (Debian, bash login) keeps the eager export in dot_profile because
# headless `chezmoi update` from SSH-bash needs the token in env up-front and
# there's no Touch ID there to interfere with anything anyway.
#
# Setup is still one-time per machine:
#   1) 1Password.com → Developer → Service Accounts → create, vault=Dotfiles, read-only
#   2) mkdir -p ~/.config/op && printf '%s' 'ops_xxx' > ~/.config/op/sa-token
#   3) chmod 600 ~/.config/op/sa-token

{{- if eq .chezmoi.os "darwin" }}
# macOS Tahoe (26.x) libsystem_malloc emits noisy warnings ("can't turn off
# malloc stack logging…" / "could not tag MSL-related memory as no_footprint")
# whenever MallocStackLogging is *present* in the environment — ANY value
# (including "0" or empty string) enables it, only an unset var means off.
# If a parent process leaked it in, strip it before any subprocess inherits.
hide-env -i MallocStackLogging
hide-env -i MallocStackLoggingNoCompact
{{- end }}

# Editor
$env.EDITOR = "nvim"
$env.VISUAL = "nvim"

# Logging
$env.LOG_FORMAT = "json"
$env.SHELL = "{{ if eq .chezmoi.os "darwin" }}/opt/homebrew/bin/nu{{ else }}/home/linuxbrew/.linuxbrew/bin/nu{{ end }}"

# Homebrew (quiet env hints; auto-update at most once per day)
$env.HOMEBREW_NO_ENV_HINTS = "1"
$env.HOMEBREW_AUTO_UPDATE_SECS = "86400"
$env.NX_TUI = true

# Config settings
$env.config.show_banner = false
$env.config.buffer_editor = "nvim"

# Load private environment variables from autoload directory
# Note: Files in ~/.config/nushell/autoload/ will be automatically sourced
use std "path add"

let home = $env.HOME

$env.PATH = ($env.PATH | split row (char esep) | prepend [
{{- if eq .chezmoi.os "darwin" }}
    "/Applications/Cursor.app/Contents/Resources/app/bin"
    "/opt/homebrew/opt/asdf/libexec/bin"
    $"($home)/Library/Application Support/carapace/bin"
    $"($home)/Library/pnpm"
    "/opt/homebrew/opt/openjdk/bin"
    "/opt/homebrew/bin"
    "/opt/homebrew/opt/mysql-client/bin"
    "/System/Cryptexes/App/usr/bin"
    "/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/local/bin"
    "/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/bin"
    "/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/appleinternal/bin"
    "/Library/Apple/usr/bin"
{{- else if eq .chezmoi.os "linux" }}
    "/home/linuxbrew/.linuxbrew/bin"
    "/home/linuxbrew/.linuxbrew/sbin"
{{- end }}
    $"($home)/.local/share/mise/shims"
    $"($home)/.cargo/bin"
    $"($home)/.bun/bin"
    $"($home)/go/bin"
    $"($home)/bin"
    $"($home)/.local/bin"
    "/usr/local/bin"
    "/usr/bin"
    "/bin"
    "/usr/sbin"
    "/sbin"
])

# PNPM config
{{- if eq .chezmoi.os "darwin" }}
$env.PNPM_HOME = ($env.HOME | path join "Library/pnpm")
{{- else }}
$env.PNPM_HOME = ($env.HOME | path join ".local/share/pnpm")
{{- end }}
# Starship config
$env.STARSHIP_CONFIG = ($env.HOME | path join ".config/starship" "starship.toml")

# Tmux config
$env.TMUX_CONFIG = ($env.HOME | path join ".config/tmux" "tmux.conf")

# Carapace config
$env.CARAPACE_BRIDGES = 'zsh,fish,bash,nushell'

# Set nvim to use nushell
$env.NVIM_SHELL = $env.SHELL

# Dotfiles bin (dot, sync-agent-skills) — globalne komendy
{{- if eq .chezmoi.os "darwin" }}
$env.DOTFILES = ($env.HOME | path join "Code/dotfiles")
{{- else }}
$env.DOTFILES = ($env.HOME | path join "dotfiles")
{{- end }}
$env.PATH = ($env.PATH | split row (char esep) | prepend ($env.DOTFILES | path join "bin"))

# Auto-trust mise configs inside the git-worktree pool (~/Code/tree/wt-*/) so
# `work new` / `work pr` worktrees don't flood "config not trusted" errors on
# every shell init. Scoped to the pool — only ever checkouts of your own repos.
$env.MISE_TRUSTED_CONFIG_PATHS = ($env.HOME | path join "Code" "tree")

{{ if stat (joinPath .chezmoi.homeDir ".config/nushell/mise.nu") -}}
source ~/.config/nushell/mise.nu
{{- end }}
