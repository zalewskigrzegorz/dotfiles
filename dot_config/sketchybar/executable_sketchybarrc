#!/usr/bin/env lua

-- Determine the configuration directory
local config_dir = os.getenv("HOME") .. "/.config/sketchybar"

-- Prepend the configuration directory to the module search paths
package.path = config_dir .. "/?.lua;" .. config_dir .. "/?/init.lua;" .. package.path
-- SbarLua's `make install` lands `sketchybar.so` in ~/.local/share/sketchybar_lua/.
-- Without that path on cpath, `require("sketchybar")` fails silently → no items
-- register → bar stays empty. This is the actual root cause of Bug 2 — fixing
-- the watcher race alone does nothing if the bindings aren't loadable.
local sbarlua_dir = os.getenv("HOME") .. "/.local/share/sketchybar_lua"
package.cpath = config_dir .. "/?.so;" .. sbarlua_dir .. "/?.so;" .. package.cpath

-- Now require the modules
require("helpers")
require("init")
