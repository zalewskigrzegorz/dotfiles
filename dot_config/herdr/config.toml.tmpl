# herdr configuration — managed by chezmoi (source: dot_config/herdr/config.toml)
# tmux+sesh replacement. Plan: bazgroly/dotfiles/plans/2026-06-28-herdr-migration-mac.md
# Backup of the old tmux setup: git tag `pre-herdr` / branch `pre-herdr-backup`.

# Onboarding wizard already done.
onboarding = false

[terminal]
# Per-OS: Mac uses the homebrew nu path; Linux (lab) resolves nu on PATH at pane spawn.
default_shell = "{{ if eq .chezmoi.os "darwin" }}/opt/homebrew/bin/nu{{ else }}/home/linuxbrew/.linuxbrew/bin/nu{{ end }}"
shell_mode = "auto"
new_cwd = "follow"

[theme]
name = "catppuccin"

# Mocha Neon overrides on top of catppuccin (see dot_config/mocha-neon/palette.lua).
# Token set is fixed: panel_bg, accent, blue, green, red, yellow (no cyan token).
[theme.custom]
panel_bg = "#1E1E2E"
accent   = "#B347FF"
blue     = "#8BE9FD"
green    = "#A6E3A1"
red      = "#FF6B9D"
yellow   = "#FFD700"

[worktrees]
directory = "~/.herdr/worktrees"

[ui]
# The whole reason for the switch: attention-queue ordering (blocked first).
agent_panel_sort = "priority"
accent = "#B347FF"
# Show detected agent labels on pane borders when no manual name is set.
show_agent_labels_on_pane_borders = true

[ui.toast]
# macOS desktop notification when a background agent changes state.
delivery = "system"
delay_seconds = 1

[ui.sound]
enabled = true

[ui.sound.agents]
claude = "on"
droid  = "off"

[session]
# "continuum for agents" — re-attach Claude conversations after a server restart.
resume_agents_on_restore = true

[keys]
# Prefix = ctrl+space — a space combo (not bare space, which would eat every space you type).
prefix = "ctrl+space"
# Cycle the agent sidebar (priority-sorted: blocked first) — the core nav. ✅ works.
next_agent = "prefix+a"
previous_agent = "prefix+shift+a"
# Open an existing worktree via herdr's native picker (work switch also does this). ✅
open_worktree = "prefix+shift+o"
# Toggle to the last pane.
last_pane = "prefix+backtick"
# Cycle workspaces. period = next ✅; comma = prev.
previous_workspace = "prefix+comma"
next_workspace = "prefix+period"
# Native remove-worktree (d = delete; `work rm` is the scripted path with confirmation).
remove_worktree = "prefix+d"
# reviewr takes plain prefix+r (r = review); resize moves to shift+r; reload → hd-reload CLI.
reload_config = ""
resize_mode = "prefix+shift+r"

# Numbered jump (focus_agent / switch_workspace by digit) is impossible here:
# ctrl+digit = AeroSpace workspaces, alt = dead (Polish option layer), cmd+digit =
# macOS/Ghostty (and cmd+shift+digit = screenshots). So navigate by cycle/picker +
# the "jump to the waiting agent" command below (prefix+0).

# Plugin keybinds (installed via run_onchange_after_34-herdr-plugins-sync).
# pluck (URL/file picker) removed — its picker pane assumes a POSIX shell and breaks
# under nu. Replaced by the `url` / `of` nu commands (autoload/herdr-pick.nu): run them
# in a shell pane to fzf-pick a link/file from the scrollback and open it.

# reviewr: toggle the code-review sidebar (r = review).
[[keys.command]]
key = "prefix+r"
type = "plugin_action"
command = "persiyanov.reviewr.toggle"
description = "Toggle reviewr code-review sidebar"

# Jump to the agent that needs you: first blocked, else done(unseen), else working
# (bin/herdr-focus-waiting). The one-key "go to the waiting agent" Greg wanted.
[[keys.command]]
key = "prefix+0"
type = "shell"
command = "/Users/greg/Code/dotfiles/bin/herdr-focus-waiting"
description = "Focus the agent that needs attention (blocked first)"

# vim-herdr-navigation NOT bound: ctrl+hjkl is AeroSpace window-focus, and alt is
# reserved for Polish diacritics (option+l=ł), so there's no clean no-prefix chord.
# Use herdr's native prefix+h/j/k/l for pane focus instead.
