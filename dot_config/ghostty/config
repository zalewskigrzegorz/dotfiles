# Mocha Neon palette (Catppuccin Mocha + bumped accents)
background = 1E1E2E
foreground = F0F0FF
cursor-color = B347FF
selection-background = 313244
selection-foreground = F0F0FF
palette = 0=#11111B
palette = 1=#FF6B9D
palette = 2=#50FA7B
palette = 3=#FFD700
palette = 4=#8AB4F8
palette = 5=#B347FF
palette = 6=#8BE9FD
palette = 7=#F0F0FF
palette = 8=#585B70
palette = 9=#FF6B9D
palette = 10=#50FA7B
palette = 11=#FFD700
palette = 12=#8AB4F8
palette = 13=#FF80BF
palette = 14=#8BE9FD
palette = 15=#F0F0FF

# Window settings
window-padding-x = 5
window-padding-y = 5
window-width = 213
window-height = 65
window-position-x = 0
window-position-y = 0

# Fonts
font-size = 17

# monospace
# ── EXPERIMENT (start 2026-06-11, ocena ~2026-06-18): Atkinson Hyperlegible Mono
#    jako font główny (czytelność prozy > ligatury), JBMono NF jako fallback na
#    nerd-glyphy. Revert: przywróć blok "old" poniżej.
font-feature = "liga"
font-feature = "calt"
font-family = "Atkinson Hyperlegible Mono"
font-family = "JetBrainsMono Nerd Font"
font-variation = wght=400

# italics
font-family-italic = "Atkinson Hyperlegible Mono"
font-variation-italic = wght=400
font-family-bold-italic = "Atkinson Hyperlegible Mono"
font-variation-bold-italic = wght=700

# old (JBMono primary):
# font-family = "JetBrainsMono Nerd Font"
# font-variation = wght=400
# font-variation = wdth=100
# font-family-italic = "JetBrainsMono Nerd Font"
# font-variation-italic = wght=400
# font-family-bold-italic = "JetBrainsMono Nerd Font"
# font-variation-bold-italic = wght=700

window-title-font-family = "JetBrainsMono Nerd Font, monospace"
macos-titlebar-style = native
macos-titlebar-proxy-icon = hidden
macos-icon = holographic
macos-icon-frame = beige
macos-option-as-alt = false
clipboard-read = allow
clipboard-write = allow
copy-on-select = false
confirm-close-surface = false
quit-after-last-window-closed = true

# Quake terminal
keybind = global:cmd+f2=toggle_quick_terminal

# Enable macos notifications
desktop-notifications = true

# Set TERM so the multiplexer (herdr) + nvim get the right terminfo
env = TERM=xterm-ghostty