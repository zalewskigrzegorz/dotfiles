{
    "workbench.colorTheme": "Catppuccin Mocha",
    "editor.inlineSuggest.enabled": true,
    "terminal.integrated.env.osx": {},
    "files.autoSave": "afterDelay",
    "bracketLens.mode": "auto",
    "bracketLens.color": "#44442E",
    "cSpell.userWords": [
        "antd",
        "asyncapi",
        "Baracus",
        "Betainsiders",
        "REDACTED_CODENAME",
        "growthbook",
        "Kratos",
        "oidc",
        "PKCE",
        "REDACTED_CLIENT",
        "SCIM",
        "SSOSAML",
        "syncer",
        "tanstack"
    ],
    "git.autofetch": true,
    "githubPullRequests.pullBranch": "never",
    "yaml.customTags": [
        "!And",
        "!And sequence",
        "!If",
        "!If sequence",
        "!Not",
        "!Not sequence",
        "!Equals",
        "!Equals sequence",
        "!Or",
        "!Or sequence",
        "!FindInMap",
        "!FindInMap sequence",
        "!Base64",
        "!Join",
        "!Join sequence",
        "!Cidr",
        "!Ref",
        "!Sub",
        "!Sub sequence",
        "!GetAtt",
        "!GetAZs",
        "!ImportValue",
        "!ImportValue sequence",
        "!Select",
        "!Select sequence",
        "!Split",
        "!Split sequence"
    ],
    "editor.minimap.scale": 3,
    "editor.minimap.size": "fit",
    "editor.accessibilitySupport": "off",
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "editor.fontFamily": "JetBrainsMono Nerd Font, monospace",
    "editor.fontLigatures": true,
    "editor.linkedEditing": true,
    "wallaby.codeLensFeature.runTest": true,
    "workbench.editor.revealIfOpen": false,
    "cody.experimental.chatPredictions": true,
    "cody.experimental.commandLenses": true,
    "cody.experimental.editorTitleCommandIcon": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "wallaby.suppressExpirationNotifications": true,
    "nxConsole.showNodeVersionOnStartup": false,
    "console-ninja.allowConsoleLogToTriggerPredictions": true,
    "console-ninja.output.showLogsFromMultipleRunningToolsTogether": true,
    "console-ninja.captureFunctions": true,
    "console-ninja.darkTheme.error.decorationAttachmentRenderOptions": {
        "border": null,
        "borderColor": null,
        "fontStyle": null,
        "fontWeight": null,
        "textDecoration": null,
        "color": "#fe536a",
        "backgroundColor": null,
        "margin": "1em",
        "width": null,
        "height": null
    },
    "console-ninja.outputMode": "In View",
    "errorLens.enableOnDiffView": true,
    "errorLens.gutterIconsEnabled": true,
    "errorLens.gutterIconSet": "emoji",
    "errorLens.problemRangeDecorationEnabled": true,
    "errorLens.followCursor": "closestProblemMultilineInViewport",
    "REDACTED_ORGOpenAPI.api.key": "***REDACTED-API-KEY***",
    "REDACTED_ORGOpenAPI.api.region": "us",
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "sonarlint.focusOnNewCode": true,
    "security.promptForLocalFileProtocolHandling": false,
    "vscode-home-assistant.hostUrl": "http://homeassistant.local:8123/",
    "remote.SSH.showLoginTerminal": true,
    "remote.SSH.useLocalServer": false,
    "remote.SSH.enableRemoteCommand": true,
    "remote.SSH.externalSSH_ASKPASS": true,
    "prisma.showPrismaDataPlatformNotification": false,
    "console-ninja.dateTimeDisplayMode": "Relative To Oldest",
    "github.copilot.editor.enableAutoCompletions": true,
    "vscode-home-assistant.ignoreCertificates": true,
    "githubCodeOwners.format.enabled": true,
    "remote.SSH.remotePlatform": {
        "homeassistant.local": "linux"
    },
    "logFileHighlighter.customPatterns": [],
    "files.associations": {
        "*.log.*": "log"
    },
    "numberedBookmarks.navigateThroughAllFiles": "replace",
    "sonarlint.rules": {},
    "editor.minimap.renderCharacters": false,
    "editor.minimap.autohide": "mouseover",
    "typescript.preferences.importModuleSpecifier": "relative",
    "typescript.preferences.importModuleSpecifierEnding": "minimal",
    "editor.foldingImportsByDefault": true,
    "editor.unicodeHighlight.nonBasicASCII": true,
    "editor.unicodeHighlight.includeComments": true,
    "workbench.editor.customLabels.patterns": {
        "**/*.ts": "${filename}.${extname} (${dirname})",
        "\"**/*.tsx": "${filename}${extname} (${dirname})",
        "**/*.js": "${filename}${extname} (${dirname})",
        "**/*.jsx": "${filename}${extname} (${dirname})",
        "**/*.json": "${filename}${extname} (${dirname})"
    },
    "workbench.iconTheme": "vscode-icons",
    "antdRush.defaultAntdMajorVersion": "^4",
    "antdRush.language": "English",
    "javascript.inlayHints.enumMemberValues.enabled": true,
    "javascript.inlayHints.parameterNames.enabled": "all",
    "javascript.inlayHints.parameterTypes.enabled": true,
    "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
    "javascript.inlayHints.variableTypes.enabled": true,
    "typescript.inlayHints.enumMemberValues.enabled": true,
    "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
    "typescript.inlayHints.parameterNames.enabled": "all",
    "typescript.inlayHints.parameterTypes.enabled": true,
    "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
    "typescript.inlayHints.variableTypes.enabled": true,
    "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
    "editor.inlayHints.padding": true,
    "chat.mcp.gallery.enabled": true,
    "terminal.integrated.mouseWheelScrollSensitivity": 3,
    "workbench.colorCustomizations": {
        "[Catppuccin Mocha]": {
            "editor.background": "#1E1E2E",
            "editor.foreground": "#F0F0FF",
            "editorCursor.foreground": "#B347FF",
            "editor.lineHighlightBackground": "#45475A",
            "editor.selectionBackground": "#B347FF55",
            "activityBar.foreground": "#B347FF",
            "activityBar.activeBorder": "#B347FF",
            "activityBarBadge.background": "#FF6B9D",
            "statusBar.background": "#1E1E2E",
            "statusBar.foreground": "#F0F0FF",
            "statusBar.border": "#B347FF",
            "sideBar.background": "#1E1E2E",
            "sideBar.foreground": "#F0F0FF",
            "list.activeSelectionBackground": "#B347FF",
            "list.activeSelectionForeground": "#1E1E2E",
            "tab.activeBorder": "#B347FF",
            "tab.activeBorderTop": "#B347FF",
            "focusBorder": "#B347FF",
            "terminal.ansiBlack": "#1E1E2E",
            "terminal.ansiRed": "#FF6B9D",
            "terminal.ansiGreen": "#50FA7B",
            "terminal.ansiYellow": "#FFD700",
            "terminal.ansiBlue": "#9580FF",
            "terminal.ansiMagenta": "#FF80BF",
            "terminal.ansiCyan": "#8BE9FD",
            "terminal.ansiWhite": "#F0F0FF",
            "panel.background": "#1E1E2E",
            "panel.border": "#B347FF",
            "panelTitle.activeBorder": "#B347FF",
            "panelTitle.activeForeground": "#F0F0FF",
            "panelTitle.inactiveForeground": "#A6ADC8",
            "panelInput.border": "#B347FF",
            "chat.background": "#1E1E2E",
            "chat.requestBackground": "#1E1E2E",
            "chat.requestBorder": "#B347FF",
            "chat.slashCommandBackground": "#B347FF",
            "chat.slashCommandForeground": "#F0F0FF",
            "chat.avatarBackground": "#B347FF",
            "chat.avatarForeground": "#1E1E2E",
            "chat.editedFileForeground": "#FF80BF",
            "interactive.activeCodeBorder": "#B347FF",
            "interactive.inactiveCodeBorder": "#45475A",
            "editorWidget.background": "#1E1E2E",
            "editorWidget.border": "#B347FF",
            "editorWidget.foreground": "#F0F0FF",
            "editorSuggestWidget.background": "#1E1E2E",
            "editorSuggestWidget.border": "#B347FF",
            "editorSuggestWidget.selectedBackground": "#B347FF",
            "editorSuggestWidget.selectedForeground": "#1E1E2E",
            "quickInput.background": "#1E1E2E",
            "quickInputTitle.background": "#B347FF",
            "button.background": "#B347FF",
            "button.foreground": "#1E1E2E",
            "button.hoverBackground": "#9580FF",
            "button.secondaryBackground": "#45475A",
            "button.secondaryForeground": "#F0F0FF",
            "input.background": "#1E1E2E",
            "input.border": "#B347FF",
            "input.foreground": "#F0F0FF",
            "input.placeholderForeground": "#A6ADC8",
            "inputOption.activeBorder": "#B347FF",
            "inputOption.activeBackground": "#B347FF55"
        }
    },
    "workbench.font.family": "JetBrainsMono Nerd Font, Arial, sans-serif",
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono, monospace",
    "editor.tokenColorCustomizations": {
        "[Catppuccin Mocha]": {
            "comments": "#A6ADC8",
            "keywords": "#B347FF",
            "strings": "#50FA7B",
            "numbers": "#FFD700",
            "types": "#8BE9FD",
            "functions": "#FF80BF",
            "variables": "#F0F0FF"
        }
    }
}