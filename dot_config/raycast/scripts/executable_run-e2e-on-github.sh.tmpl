#!/bin/bash

# @raycast.schemaVersion 1
# @raycast.title Run E2E on GitHub
# @raycast.mode compact

# @raycast.icon 🚀
# @raycast.packageName GitHub Automation

# Documentation:
# @raycast.description Runs end-to-end tests on GitHub by toggling the run_e2e label.
# @raycast.author Grzegorz Zalewski
# @raycast.authorURL https://raycast.com/zalewskigrzegorz
{{- $vault := "Dotfiles" -}}
{{- with (index . "onePasswordVault") -}}
{{- $vault = . -}}
{{- end }}

workspace_dir={{ onepasswordRead (printf "op://%s/WORKSPACE_DIR/password" $vault) | quote }}
work_company={{ onepasswordRead (printf "op://%s/WORK_COMPANY/password" $vault) | quote }}
work_main_project={{ onepasswordRead (printf "op://%s/WORK_MAIN_PROJECT/password" $vault) | quote }}
work_project_dir="${workspace_dir}/${work_company}/${work_main_project}"

if [ -z "$work_project_dir" ] || [ ! -d "$work_project_dir" ]; then
  echo "Rendered WORK_PROJECT_DIR must point to your monorepo clone root." >&2
  exit 1
fi
cd "$work_project_dir" || exit 1

gh pr edit --remove-label run_e2e
gh pr edit --add-label run_e2e

echo "E2E tests triggered successfully on GitHub"
