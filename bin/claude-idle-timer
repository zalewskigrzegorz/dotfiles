#!/usr/bin/env bash
# ~/Code/dotfiles/bin/claude-idle-timer
# Fires `claude_sessions_idle_check` event every 30s so sketchybar
# re-evaluates idle→waiting transitions (no FS event when a transcript
# simply stops being touched).
set -euo pipefail

INTERVAL="${CLAUDE_IDLE_INTERVAL_SEC:-30}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

while sleep "$INTERVAL"; do
  "$SCRIPT_DIR/claude-sessions-render" 2>/dev/null || true
done
