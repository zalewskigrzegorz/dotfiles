#!/usr/bin/env bash
# ~/Code/dotfiles/bin/sketchybar-restart
# Clean restart: kill watcher → kill sketchybar → restart service → wait for
# ready → start watcher → health probe (PASS/FAIL per item).
set -e

GREEN='\033[38;2;80;250;123m'
RED='\033[38;2;255;107;157m'
MAUVE='\033[38;2;179;71;255m'
N='\033[0m'

# 1. Stop watcher first so its retry loop doesn't fight us.
pkill -9 -f sketchybar-watcher 2>/dev/null || true

# 2. Stop sketchybar (service + any orphan).
brew services stop sketchybar >/dev/null 2>&1 || true
pkill -9 -x sketchybar 2>/dev/null || true
sleep 1

# 3. Restart sketchybar daemon.
brew services start sketchybar >/dev/null 2>&1

# 4. Wait until the bar responds before relaunching watcher.
for _ in $(seq 1 50); do
    if /opt/homebrew/bin/sketchybar --query bar >/dev/null 2>&1; then
        break
    fi
    sleep 0.2
done

# 5. Relaunch watcher (aerospace will not, because we removed the line in Task 5).
nohup "$HOME/Code/dotfiles/bin/sketchybar-watcher/sketchybar-watcher" \
    >> "$HOME/Code/dotfiles/logs/sketchybar-watcher.log" 2>&1 &
WATCHER_PID=$!

# Give the lua sketchybarrc time to register items + watcher to push state.
sleep 3

# 6. Health probe — every item expected to exist gets queried. Per-item PASS
# /FAIL so a missing widget is visible right after restart, not 5 minutes later.
printf "${MAUVE}sketchybar restarted${N}; watcher PID %s\n" "$WATCHER_PID"
printf "${MAUVE}health probe:${N}\n"

EXPECTED=(
  # core / static
  apple front_app notif_preview
  # widgets
  widgets.battery widgets.cpu widgets.wifi1 widgets.wifi2
  widgets.volume1 widgets.volume2 widgets.mic1 widgets.mic2
  widgets.claude_sessions
  # workspaces (item.1..10 — set up by spaces.lua)
  item.1 item.2 item.3 item.4 item.5 item.6 item.7 item.8 item.9 item.10
)

PASS=0
FAIL=0
MISSING=()
for name in "${EXPECTED[@]}"; do
    if /opt/homebrew/bin/sketchybar --query "$name" >/dev/null 2>&1; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        MISSING+=("$name")
    fi
done

if (( FAIL == 0 )); then
    printf "  ${GREEN}✓ all %d items present${N}\n" "$PASS"
else
    printf "  ${RED}✗ %d/%d items missing:${N}\n" "$FAIL" "${#EXPECTED[@]}"
    for m in "${MISSING[@]}"; do
        printf "    ${RED}- %s${N}\n" "$m"
    done
    printf "  ${GREEN}✓ %d items present${N}\n" "$PASS"
fi
