#!/usr/bin/env bash
# Focus a Claude session: switch tmux to <session> (if given) and surface
# Ghostty. Shared by the Notification hook and the sketchybar chip click.
#
# Surfacing Ghostty is two problems:
#   1. AeroSpace (tiling WM) parks inactive workspaces off-screen, so a tmux
#      switch alone leaves Ghostty's window invisible on another workspace.
#      `aerospace focus --window-id <id>` pulls that workspace to the front
#      AND focuses the window — idempotent if we're already there.
#   2. macOS app activation: `open -a Ghostty` ALWAYS spawns a fresh window
#      when the app is already running — wrong here. The osascript `activate`
#      raises the existing window instead. Used only as the fallback when
#      AeroSpace is unavailable or has no Ghostty window.
set -u
# launchd (AeroSpace/sketchybar) starts us with no locale → C, which breaks
# bash read/assoc-array on multibyte session names (emoji). Force UTF-8.
export LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
sess="${1:-}"
TMUX_BIN="${TMUX_BIN:-/opt/homebrew/bin/tmux}"
OSASCRIPT="${OSASCRIPT:-/usr/bin/osascript}"
AEROSPACE="${AEROSPACE:-/opt/homebrew/bin/aerospace}"

if [ -n "$sess" ]; then
  "$TMUX_BIN" switch-client -t "$sess" >/dev/null 2>&1 || true
fi

# Pull Ghostty's AeroSpace workspace to the front. Returns non-zero if
# aerospace is missing or no Ghostty window exists → osascript fallback.
focus_aerospace() {
  [ -x "$AEROSPACE" ] || return 1
  local wid
  wid=$("$AEROSPACE" list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
    | awk -F'|' 'tolower($2) ~ /ghostty/ { gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1; exit }')
  [ -n "$wid" ] || return 1
  "$AEROSPACE" focus --window-id "$wid" >/dev/null 2>&1
}

focus_aerospace || "$OSASCRIPT" -e 'tell application "Ghostty" to activate' >/dev/null 2>&1 || true
exit 0
