#!/usr/bin/env bash
# Focus a Claude session: switch tmux to <session> (if given) and raise
# Ghostty's EXISTING window only when needed. Shared by the Notification hook
# and the sketchybar chip click. The key trick: `open -a Ghostty` ALWAYS opens
# a fresh window when the app is already running — wrong here. So we use
# osascript `tell application "Ghostty" to activate`, which raises the
# existing window without spawning a new one. And we only fall back to
# activating Ghostty when tmux switch wasn't possible (no attached client).
set -u
sess="${1:-}"
TMUX_BIN="${TMUX_BIN:-/opt/homebrew/bin/tmux}"
OSASCRIPT="${OSASCRIPT:-/usr/bin/osascript}"

switched=0
if [ -n "$sess" ]; then
  if "$TMUX_BIN" switch-client -t "$sess" >/dev/null 2>&1; then
    switched=1
  fi
fi

if [ "$switched" -eq 0 ]; then
  "$OSASCRIPT" -e 'tell application "Ghostty" to activate' >/dev/null 2>&1 || true
fi
exit 0
