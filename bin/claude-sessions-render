#!/usr/bin/env bash
# ~/Code/dotfiles/bin/claude-sessions-render
# Run `claude-sessions inline`, write result to /tmp/claude-sessions-display-<uid>.txt atomically.
# Called by claude-watcher (on FS event) and claude-idle-timer (every 30s).
# Widget reads the file via pure Lua io.open — no shell spawn needed on refresh.
set -euo pipefail

DISPLAY_FILE="${CLAUDE_SESSIONS_DISPLAY:-/tmp/claude-sessions-display-$(id -u).txt}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

output=$("$SCRIPT_DIR/claude-sessions" inline 2>/dev/null || echo "")

# Treat "—" (em-dash when total=0) as empty so widget hides
if [ -z "$output" ] || [ "$output" = "—" ]; then
  : > "$DISPLAY_FILE.tmp"
else
  printf '%s\n' "$output" > "$DISPLAY_FILE.tmp"
fi
mv "$DISPLAY_FILE.tmp" "$DISPLAY_FILE"

# Trigger sketchybar so widget re-reads the file
if [ "$(uname -s)" = "Darwin" ] && command -v sketchybar >/dev/null 2>&1; then
  sketchybar --trigger claude_sessions_changed 2>/dev/null || true
fi
