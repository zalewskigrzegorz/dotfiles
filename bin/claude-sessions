#!/usr/bin/env bash
# ~/Code/dotfiles/bin/claude-sessions
# List active Claude Code sessions. Cache-backed, fswatch-invalidated.
# Subcommands: count | --json | waiting
set -euo pipefail

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
CACHE_FILE="${CLAUDE_SESSIONS_CACHE:-/tmp/claude-sessions-$(id -u).json}"
ACTIVE_WINDOW_SEC=600   # files modified in last 10 min are "active"
WAIT_THRESHOLD_SEC=30   # idle > 30s after assistant_text_end → "waiting"

usage() {
  cat <<'EOF'
Usage: claude-sessions <subcommand>
  count      Print integer count of active sessions
  --json     Print JSON array (one entry per active session)
  waiting    Print one line per waiting session: <project>\t<session_id>
  inline     Print compact status-bar string: "N [project]" (1-2 sessions) or "N" / "N K" (>2)
  summary    Print full per-project breakdown (for popups / terminals)
EOF
}

# Map a target cwd (e.g. /Users/greg/Code/dotfiles) to a tmux session name
# by searching tmux panes. Empty string if no tmux or no match.
tmux_session_for_cwd() {
  local target_cwd="$1"
  command -v tmux >/dev/null 2>&1 || { echo ""; return; }
  tmux list-panes -aF '#{session_name}'$'\t''#{pane_current_path}' 2>/dev/null \
    | awk -F'\t' -v cwd="$target_cwd" '
        index($2, cwd) == 1 { print $1; exit }
      ' \
    | head -n 1
}

rebuild_cache() {
  local now items=()
  now=$(date +%s)
  shopt -s nullglob
  for f in "$PROJECTS_DIR"/*/*.jsonl; do
    local mtime
    mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
    (( now - mtime > ACTIVE_WINDOW_SEC )) && continue
    local last_event
    last_event=$(tail -n 1 "$f" 2>/dev/null | jq -r '.type // empty' 2>/dev/null || echo "")
    local project_dir project sid waiting
    project_dir=$(dirname "$f")
    project=$(basename "$project_dir" | sed 's|^-||; s|-|/|g')
    sid=$(basename "$f" .jsonl)
    waiting=false
    if [[ "$last_event" == "assistant_text_end" ]] && (( now - mtime > WAIT_THRESHOLD_SEC )); then
      waiting=true
    fi
    local target_cwd="/$project"
    local tmux_sess; tmux_sess=$(tmux_session_for_cwd "$target_cwd" || echo "")
    items+=("$(jq -n \
      --arg project "$project" \
      --arg sid "$sid" \
      --arg tmux_session "$tmux_sess" \
      --argjson mtime "$mtime" \
      --argjson waiting "$waiting" \
      '{project:$project, session_id:$sid, tmux_session:$tmux_session, mtime:$mtime, waiting:$waiting}')")
  done
  shopt -u nullglob
  local tmp="$CACHE_FILE.tmp.$$"
  if (( ${#items[@]} == 0 )); then
    echo '[]' > "$tmp"
  else
    printf '%s\n' "${items[@]}" | jq -s '.' > "$tmp"
  fi
  mv "$tmp" "$CACHE_FILE"
}

ensure_cache() {
  [[ -f "$CACHE_FILE" ]] || rebuild_cache
}

safe_jq() {
  # Read cache via jq. If file vanished or is corrupt, rebuild once and retry.
  local filter="$1"
  jq -r "$filter" "$CACHE_FILE" 2>/dev/null && return 0
  rebuild_cache
  jq -r "$filter" "$CACHE_FILE" 2>/dev/null || echo ""
}

cmd_count() {
  ensure_cache
  local n; n=$(safe_jq 'length')
  echo "${n:-0}"
}

cmd_inline() {
  ensure_cache
  local total waiting projects
  total=$(safe_jq 'length')
  waiting=$(safe_jq '[.[] | select(.waiting)] | length')
  [ -z "$total" ] && total=0
  [ -z "$waiting" ] && waiting=0
  # Show project names if 1-2 sessions, just count if more
  if [ "$total" -ge 1 ] && [ "$total" -le 2 ]; then
    projects=$(safe_jq '[.[].project | split("/") | .[-1]] | unique | join("+")')
    [ -z "$projects" ] && projects=""
    if [ "$waiting" -gt 0 ]; then
      printf '%s  %s %s\n' "$total" "$projects" "$waiting"
    elif [ -n "$projects" ]; then
      printf '%s %s\n' "$total" "$projects"
    else
      printf '%s\n' "$total"
    fi
  else
    if [ "$waiting" -gt 0 ]; then
      printf '%s  %s\n' "$total" "$waiting"
    else
      printf '%s\n' "$total"
    fi
  fi
}

cmd_summary() {
  ensure_cache
  local total waiting projects
  total=$(safe_jq 'length')
  waiting=$(safe_jq '[.[] | select(.waiting)] | length')
  projects=$(safe_jq '[.[].project] | unique | join(", ")')
  [ -z "$total" ] && total=0
  [ -z "$waiting" ] && waiting=0
  [ -z "$projects" ] && projects="(none)"
  cat <<EOF
 Claude sessions: $total active · $waiting waiting

Projects: $projects

Per session:
EOF
  safe_jq '.[] | "  • \(.project) [\(.session_id[0:8])] " + (if .waiting then " waiting" else "active" end) + " — mtime: \(.mtime|todate)"'
}

case "${1:-}" in
  count)        cmd_count ;;
  --json|json)  shift || true; ensure_cache; safe_jq '.' ;;
  waiting)      ensure_cache; safe_jq '.[] | select(.waiting) | "\(.project)\t\(.session_id)"' ;;
  inline)       cmd_inline ;;
  summary)      cmd_summary ;;
  -h|--help|"") usage ;;
  *) echo "unknown subcommand: $1" >&2; usage >&2; exit 2 ;;
esac
