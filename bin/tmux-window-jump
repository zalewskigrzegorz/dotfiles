#!/usr/bin/env bash
# tmux-window-jump — jump to the Claude agent that needs you. Candidates are
# Claude windows in state blocked (🔴 permission/action) or waiting (⏳ turn done
# / idle); running agents and the window you're already on are excluded. Sorted
# blocked-first. 0 candidates → silent exit; 1 → jump straight there; >1 → a
# floating picker. Bound to cmd-ctrl-w in aerospace.toml.
#
# Switching uses tmux IDs ($session / @window) + an explicit -c <client>, NOT the
# session NAME: switch-client -t <name> silently no-ops (rc=0) for names with
# emoji/slashes (fnmatch), and from AeroSpace (no $TMUX) it needs the client named
# explicitly. IDs are ASCII + unambiguous, sidestepping both.
set -euo pipefail
# launchd (AeroSpace/sketchybar) starts us with no locale → C, which breaks
# bash read/assoc-array on multibyte session names (emoji). Force UTF-8.
export LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
export PATH="/opt/homebrew/bin:$PATH"
STATE_BIN="${CLAUDE_AGENT_STATE_BIN:-$HOME/Code/dotfiles/bin/claude-agent-state}"
FOCUS_BIN="${CLAUDE_FOCUS_BIN:-$HOME/Code/dotfiles/bin/claude-focus-session}"
# tmux/choose overridable for tests — the PATH prepend above would otherwise
# shadow any PATH-injected shim with the real binaries.
TMUX_BIN="${TMUX_BIN:-/opt/homebrew/bin/tmux}"
CHOOSE_BIN="${CHOOSE_BIN:-choose}"

# Exclude the window we're on — jumping to where you already are is pointless.
CUR=$("$TMUX_BIN" display-message -p '#{session_name}:#{window_index}' 2>/dev/null || true)

# Presence map keyed by session:window_index (from claude-agent-state, which
# already includes fallback-detected claude windows). rank: blocked 0, waiting 1.
# Command-substitution + here-string, NOT `done < <(...)`: process substitution
# yields nothing when launched from AeroSpace (no usable /dev/fd), which left the
# picker empty \u2192 cmd-ctrl-w did nothing.
declare -A GLYPH RANK
STATE_LIST=$("$STATE_BIN" list 2>/dev/null || true)
while IFS=$'\t' read -r st tg _rest; do
  [ -n "$tg" ] || continue
  case "$st" in
    blocked) GLYPH[$tg]=$'\uf071'; RANK[$tg]=0 ;;
    waiting) GLYPH[$tg]=$'\uf017'; RANK[$tg]=1 ;;
  esac
done <<< "$STATE_LIST"

# Row: rank \t session_id \t window_id \t label(+glyph). Keep only blocked/waiting
# windows, excluding the current one.
rows=""
WINDOWS=$("$TMUX_BIN" list-windows -a -F '#{session_id}	#{window_id}	#{session_name}:#{window_index}	#{session_name}  ·  #{window_index} #{window_name}' 2>/dev/null || true)
while IFS=$'\t' read -r sid wid sikey label; do
  [ -n "$wid" ] || continue
  [ -n "${RANK[$sikey]:-}" ] || continue
  [ "$sikey" = "$CUR" ] && continue
  g="${GLYPH[$sikey]}"; r="${RANK[$sikey]}"
  rows+="$r"$'\t'"$sid"$'\t'"$wid"$'\t'"$g  $label"$'\n'
done <<< "$WINDOWS"

rows=$(printf '%s' "$rows" | sed '/^$/d' | sort -t$'\t' -k1,1n)
[ -n "$rows" ] || exit 0

jump() {  # $1=session_id ($N)  $2=window_id (@N)
  local client
  client=$("$TMUX_BIN" list-clients -F '#{client_name}' 2>/dev/null | head -1)
  if [ -n "$client" ]; then
    "$TMUX_BIN" switch-client -c "$client" -t "$1" 2>/dev/null || true
  else
    "$TMUX_BIN" switch-client -t "$1" 2>/dev/null || true
  fi
  "$TMUX_BIN" select-window -t "$2" 2>/dev/null || true
  exec "$FOCUS_BIN"
}

# Exactly one candidate → jump straight away.
if [ "$(printf '%s\n' "$rows" | wc -l | tr -d ' ')" = "1" ]; then
  jump "$(printf '%s' "$rows" | cut -f2)" "$(printf '%s' "$rows" | cut -f3)"
fi

idx=$(printf '%s\n' "$rows" | cut -f4- \
        | "$CHOOSE_BIN" -i -z -a -n 14 -w 80 -p agents -f 'JetBrainsMono Nerd Font Mono' -s 32 -c 8BE9FD -b B347FF) || exit 0
case "$idx" in ''|*[!0-9]*) exit 0 ;; esac
row=$(printf '%s\n' "$rows" | sed -n "$((idx + 1))p")
[ -n "$row" ] || exit 0
jump "$(printf '%s' "$row" | cut -f2)" "$(printf '%s' "$row" | cut -f3)"
