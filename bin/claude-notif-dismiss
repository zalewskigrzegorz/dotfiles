#!/usr/bin/env bash
# Dismiss any pending "Claude is waiting" alerter notification matching the
# given tmux session (or the current one when called without args).
# Used by:
#   - tmux client-session-changed hook (auto-dismiss when user switches session)
#   - bin/claude-focus-session (after switching to the waiting session)
# Notification groups are named "claude-wait-<session>" by notify-waiting.sh.
# `alerter --remove` is a no-op for non-existent groups, so this is safe to fire
# on every session change.
set -u
sess="${1:-}"
if [ -z "$sess" ]; then
  sess=$(tmux display-message -p '#{session_name}' 2>/dev/null || true)
fi
[ -n "$sess" ] || exit 0
ALERTER="${ALERTER:-/opt/homebrew/bin/alerter}"
"$ALERTER" --remove "claude-wait-$sess" >/dev/null 2>&1 || true
exit 0
