#!/usr/bin/env bash
set -euo pipefail

if [[ -d /home/linuxbrew/.linuxbrew/bin ]]; then
  PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
fi
if [[ -d /opt/homebrew/bin ]]; then
  PATH="/opt/homebrew/bin:$PATH"
fi
export PATH

secret_dir="${DOTFILES_SECRET_DIR:-$HOME/.local/state/dotfiles/secrets}"
private_config="${DOTFILES_GITLEAKS_PRIVATE_CONFIG:-$secret_dir/gitleaks-private.toml}"

gitleaks detect --source . --config .gitleaks.toml "$@"

if [[ ! -f "$private_config" ]]; then
  if [[ "${DOTFILES_SKIP_PRIVATE_GITLEAKS:-0}" == "1" ]]; then
    echo "Private gitleaks rules SKIPPED via DOTFILES_SKIP_PRIVATE_GITLEAKS=1." >&2
    exit 0
  fi
  echo "FAIL: private gitleaks config missing: $private_config" >&2
  echo "Run sync to restore it from 1Password (a missing private config is a hole, not a pass)." >&2
  echo "One-off bypass: DOTFILES_SKIP_PRIVATE_GITLEAKS=1 bin/gitleaks-dotfiles" >&2
  exit 1
fi

gitleaks detect --source . --config "$private_config" "$@"
