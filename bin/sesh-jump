#!/usr/bin/env bash
# sesh-jump — native floating sesh picker for a global hotkey.
#
# Pops a choose-gui list of sesh targets (tmux sessions + configs + zoxide
# dirs), then `sesh connect -s` (switch, NOT attach — `-s` is meant for
# triggers fired outside a terminal) and surfaces Ghostty via AeroSpace.
# No terminal window, no tiling. Bound to cmd-ctrl-s in aerospace.toml —
# the native replacement for the Raycast Sesh extension.
set -euo pipefail
export PATH="/opt/homebrew/bin:$PATH"   # exec-and-forget gives a minimal PATH

# Dedupe sesh's multi-source list (a name can appear as tmux session + config
# + zoxide path). choose returns the picked line verbatim; sesh connect takes
# either a session name or a path, so no index round-trip is needed.
sel=$(sesh list | awk '!seen[$0]++' \
        | choose -z -a -n 12 -w 72 -p sesh -f 'JetBrainsMono Nerd Font Mono' -s 32 -c 8BE9FD -b B347FF) || exit 0
[ -n "$sel" ] || exit 0

if tmux list-clients 2>/dev/null | grep -q .; then
  # A client is attached → switch it in place, then pull Ghostty to the front.
  sesh connect -s "$sel"
  exec "$HOME/Code/dotfiles/bin/claude-focus-session"
else
  # No tmux client anywhere → open a fresh Ghostty attached to the session.
  exec open -na Ghostty --args -e sesh connect "$sel"
fi
