#!/bin/bash
# sesh wrapper — forces POSIX UTF-8 locale before exec'ing real sesh.
#
# Why: sesh 2.26.2 falls back to C locale (and strips non-BMP runes like
# emoji to `__` in its internal name resolution) when its inherited LC_*
# env isn't parseable as a POSIX locale. Raycast (Beta especially) passes
# LC_ALL as a BCP 47 tag like
#   en-US-u-ca-gregory-co-standard-cu-pln-fw-mon-hc-h23-ms-metric-rg-plzzzz-tz-plwaw
# which is NOT POSIX format — sesh can't parse it and degrades to C.
# LC_ALL overrides LC_CTYPE per POSIX, so just setting LC_CTYPE doesn't
# help; we must override LC_ALL itself.
#
# Effect: `work new` worktree sessions named with emoji (🌿<repo>/<emoji><branch>)
# become switchable from Raycast.
#
# Install: add this dir (~/Code/dotfiles/bin) to the Raycast Sesh extension's
# `environmentPath` preference, BEFORE `/opt/homebrew/bin`. Wrapper takes
# over, fixes locale, execs the real sesh binary.
#
# Source of truth: ~/Code/dotfiles/bin/sesh (chezmoi-managed).
# Related: ~/Code/personal/bazgroly/dotfiles/analysis/2026-06-02-sesh-emoji-bug-and-work-new-race.md

export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LANG=en_US.UTF-8

# Hardcoded path to real sesh — homebrew arm64 install on Greg's Mac.
exec /opt/homebrew/bin/sesh "$@"
