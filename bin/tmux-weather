#!/usr/bin/env bash
# bin/tmux-weather
# Emits a weather chip for tmux status-right.
#   * Always shows the current temperature on a neutral chip.
#   * Upgrades to a colored alert chip (icon + bg + +4h forecast + precip) when:
#       - rain / snow predicted now or in next 4h (precip_mm >= 0.1 or chance >= 20%)
#       - wind > 20 km/h
#       - thunderstorm / fog / blizzard in description
#       - temp <= 0°C or >= 30°C
# Format on alert: " <icon> now <temp> → in <Nh> <icon2> <peak> " with
# per-condition bg colour (rain=lavender, wind=cyan, storm=red, snow=white,
# heat=orange, cold=blue, AQI=mauve).
#
# Cached 5min. wttr.in JSON with IP-based location, metric units.
set -euo pipefail

CACHE_TTL=300
uid="${UID:-$(id -u)}"
cache="${TMPDIR:-/tmp}/tmux-weather-${uid}"

if [[ -f "$cache" ]]; then
  mtime=$(stat -f %m "$cache" 2>/dev/null || echo 0)
  if (( $(date +%s) - mtime < CACHE_TTL )); then
    cat "$cache"
    exit 0
  fi
fi

emit() { printf '%s' "$1" > "$cache.tmp" && mv "$cache.tmp" "$cache"; printf '%s' "$1"; }

command -v jq >/dev/null || { emit ""; exit 0; }

json=$(curl -sS --max-time 4 'wttr.in/?format=j1' 2>/dev/null || true)
[[ -z "$json" || ! "$json" =~ ^\{ ]] && { emit ""; exit 0; }

# Current snapshot.
cur_temp=$(echo "$json"     | jq -r '.current_condition[0].temp_C        // empty')
cur_desc=$(echo "$json"     | jq -r '.current_condition[0].weatherDesc[0].value // empty' | tr '[:upper:]' '[:lower:]')
cur_wind=$(echo "$json"     | jq -r '.current_condition[0].windspeedKmph // 0')

# Next-4h forecast. wttr's hourly[] is indexed by 3h slots (0, 300, 600, 900, ...)
# within "today" first, then weather[1].hourly[] for tomorrow. We pull from
# weather[0..1] flat and find the slot whose `time` is between now+2h and now+5h.
now_hhmm=$(date +%H%M)
now_mins=$(( 10#${now_hhmm:0:2} * 60 + 10#${now_hhmm:2:2} ))
target_mins=$(( now_mins + 240 ))  # +4h
wrap_target=$target_mins
if (( wrap_target >= 1440 )); then
  wrap_target=$(( wrap_target - 1440 ))
  day_index=1
else
  day_index=0
fi

next=$(echo "$json" | jq --argjson t "$wrap_target" --argjson d "$day_index" '
  .weather[$d].hourly
  | map({time: (.time|tonumber|((./100|floor)*60 + (.%100))), data: .})
  | (map(select(.time >= $t)) | first) // (.[-1])
  | .data
' 2>/dev/null)

next_temp=$(echo "$next" | jq -r '.tempC          // empty')
next_desc=$(echo "$next" | jq -r '.weatherDesc[0].value // empty' | tr '[:upper:]' '[:lower:]')
next_rain=$(echo "$next" | jq -r '.precipMM       // 0')
next_wind=$(echo "$next" | jq -r '.windspeedKmph  // 0')
next_chance_rain=$(echo "$next" | jq -r '.chanceofrain // 0')
next_chance_snow=$(echo "$next" | jq -r '.chanceofsnow // 0')

# Pick category by current-or-next signal. Order = priority.
icon=""; bg=""; alert=""
contains() { case "$2" in *"$1"*) return 0;; *) return 1;; esac; }

if   contains "thunder" "$cur_desc" || contains "thunder" "$next_desc"; then
  icon="⛈"; bg="#FF6B9D"; alert="storm"
elif contains "blizzard" "$cur_desc" || contains "blizzard" "$next_desc"; then
  icon="❄"; bg="#F0F0FF"; alert="blizzard"
elif contains "snow" "$cur_desc" || contains "snow" "$next_desc" || (( next_chance_snow >= 20 )); then
  icon="❄"; bg="#8BE9FD"; alert="snow"
elif contains "fog" "$cur_desc" || contains "fog" "$next_desc" || contains "mist" "$cur_desc"; then
  icon="🌫"; bg="#7F849C"; alert="fog"
elif awk "BEGIN{exit !($next_rain >= 0.1 || $next_chance_rain >= 20)}"; then
  icon="🌧"; bg="#9580FF"; alert="rain"
elif awk "BEGIN{exit !($cur_wind > 20 || $next_wind > 20)}"; then
  icon="💨"; bg="#8BE9FD"; alert="wind"
elif awk "BEGIN{exit !($cur_temp != \"\" && ($cur_temp + 0) >= 30)}"; then
  icon="🔥"; bg="#FF8C42"; alert="heat"
elif awk "BEGIN{exit !($cur_temp != \"\" && ($cur_temp + 0) <= 0)}"; then
  icon="🥶"; bg="#9580FF"; alert="cold"
fi

# Always show temperature. Alert (if any) adds icon + colored bg + forecast.
hrs_ahead=4
if [[ -z "$alert" ]]; then
  # Calm chip: just current temp on neutral surface.
  [[ -z "$cur_temp" ]] && { emit ""; exit 0; }
  emit "#[bg=#313244,fg=#CDD6F4,nobold] ${cur_temp}° #[bg=#1E1E2E,fg=#F0F0FF]"
  exit 0
fi

chip=" ${icon} ${cur_temp}°"
if [[ -n "$next_temp" && "$next_temp" != "$cur_temp" ]]; then
  chip+=" → +${hrs_ahead}h ${next_temp}°"
fi
# Add precip mm if material.
if awk "BEGIN{exit !($next_rain >= 0.1)}"; then
  chip+=" ${next_rain}mm"
fi
chip+=" "

emit "#[bg=${bg},fg=#1E1E2E,bold]${chip}#[bg=#1E1E2E,fg=#F0F0FF,nobold]"
