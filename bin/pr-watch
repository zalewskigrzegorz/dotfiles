#!/usr/bin/env nu

# pr-watch — poll GitHub for actionable PRs of mine, push state to the SketchyBar
# `pr_watch` chip. Run by launchd every 3 min (com.greg.pr-watch). PUSH-driven:
# ends with `sketchybar --set` just like bin/claude-agent-chip.
#
# "Actionable" mirrors bin/prs action logic — a PR needs MY action when it is
# ready to MERGE, has CHANGES_REQUESTED, or has failing CI ("fix CI"). PRs that
# wait on others (needs review / draft / blocked) are NOT actionable → chip stays
# hidden for them.
#
# Thread delta: for actionable PRs only (cheap — usually 0-2), we fetch the
# unresolved review-thread count. A rise vs cache flags `new_comments` (gold
# accent), so a fresh reply on a PR you must act on stands out.
#
# Cache: ~/.cache/pr-watch-last.json  { "<num>": {action, threads, actionable, title, url} }

const REPO = "Redocly/redocly"
const FIELDS = "number,title,isDraft,reviewDecision,mergeable,statusCheckRollup,headRefName,url"

# Nerd Font glyphs — picked to be self-explanatory AND visually distinct from each
# other (the two git octicons looked alike at chip size). Also disjoint from the
# claude_agents chip (FA clock/warning/circle).
const G_FIX = "\u{f0ad}"     # wrench   — changes req / fix CI (needs your fix)
const G_MERGE = "\u{f00c}"   # check    — ready to merge
const G_COMMENT = "\u{f075}" # comment  — new unresolved thread since last poll

# State colors — dynamic like the agents chip, but drawn from hues the agents
# chip NEVER uses (it cycles red/gold/mauve) so the two pills don't blend when
# adjacent. Mirror dot_config/sketchybar/colors.lua.
const C_FIX = "0xffff8c42"   # orange — needs your fix (urgent, but not agents' red)
const C_MERGE = "0xff50fa7b" # green  — ready to merge
const C_NEW = "0xff8be9fd"   # cyan   — new comment

def set-chip [args: list<string>] {
    if (which sketchybar | is-not-empty) {
        ^sketchybar --set pr_watch ...$args | ignore
    }
}

# Count unresolved review threads — only reachable via GraphQL (gh pr view --json
# has no reviewThreads field). Returns -1 on failure so the caller keeps the cache.
def unresolved-thread-count [num: int]: nothing -> int {
    let parts = ($REPO | split row "/")
    let q = 'query($owner:String!,$name:String!,$num:Int!){repository(owner:$owner,name:$name){pullRequest(number:$num){reviewThreads(first:100){nodes{isResolved}}}}}'
    let r = (do {
        ^gh api graphql -f $"query=($q)" -F $"owner=($parts.0)" -F $"name=($parts.1)" -F $"num=($num)"
    } | complete)
    if $r.exit_code != 0 { return (-1) }
    ($r.stdout | from json | get -o data.repository.pullRequest.reviewThreads.nodes | default []
        | where {|t| not ($t | get -o isResolved | default false)} | length)
}

def main [] {
    let cache_path = ($env.HOME | path join ".cache" "pr-watch-last.json")
    let prev = (if ($cache_path | path exists) {
        (try { open $cache_path } catch { {} })
    } else { {} })

    let listed = (do { ^gh pr list --author "@me" --repo $REPO --state open --json $FIELDS --limit 30 } | complete)
    if $listed.exit_code != 0 {
        # gh failed (offline / auth) → leave the chip untouched, try again next poll.
        exit 0
    }
    let prs = ($listed.stdout | from json)

    let rows = ($prs | each { |pr|
        let failed = ($pr.statusCheckRollup | where {|c| ($c | get -o conclusion) == "FAILURE"} | length)
        let review = ($pr | get -o reviewDecision | default "")
        let draft = $pr.isDraft
        let action = (
            if $draft and $failed > 0            { "draft+CI" }
            else if $draft                       { "draft" }
            else if $failed > 0                  { "fix CI" }
            else if $review == "CHANGES_REQUESTED" { "changes req" }
            else if $review == "REVIEW_REQUIRED"   { "needs review" }
            else if $pr.mergeable == "MERGEABLE"   { "MERGE" }
            else                                    { "blocked" }
        )
        let actionable = ($action in ["MERGE" "changes req" "fix CI"])
        {number: $pr.number, action: $action, title: $pr.title, url: $pr.url, actionable: $actionable}
    })

    # Thread counts — actionable PRs only (cheap: one `gh pr view` each).
    let enriched = ($rows | each { |r|
        let key = ($r.number | into string)
        let prev_threads = ($prev | get -o $key | get -o threads | default 0)
        if not $r.actionable {
            { ...$r, threads: $prev_threads, new_comments: false }
        } else {
            let c = (unresolved-thread-count $r.number)
            let threads = (if $c >= 0 { $c } else { $prev_threads })
            { ...$r, threads: $threads, new_comments: ($threads > $prev_threads) }
        }
    })

    # Persist cache (all PRs, so non-actionable thread counts survive too).
    let cache = ($enriched | reduce -f {} { |r, acc|
        $acc | insert ($r.number | into string) {
            action: $r.action, threads: $r.threads, actionable: $r.actionable, title: $r.title, url: $r.url
        }
    })
    mkdir ($cache_path | path dirname)
    $cache | to json | save -f $cache_path

    # Build chip from actionable PRs.
    let act = ($enriched | where actionable)
    if ($act | is-empty) {
        set-chip ["drawing=off"]
        return
    }

    let n_fix = ($act | where action in ["fix CI" "changes req"] | length)
    let n_merge = ($act | where action == "MERGE" | length)
    let n_new = ($act | where new_comments | length)

    mut parts = []
    if $n_fix > 0   { $parts = ($parts | append $"($G_FIX) ($n_fix)") }
    if $n_merge > 0 { $parts = ($parts | append $"($G_MERGE) ($n_merge)") }
    if $n_new > 0   { $parts = ($parts | append $"($G_COMMENT) ($n_new)") }
    let label = ($parts | str join "   ")

    # Urgency color drives BOTH border and label text (single label can't color
    # per-segment): orange (needs fix) > cyan (new comment) > green (merge).
    let bcolor = (if $n_fix > 0 { $C_FIX } else if $n_new > 0 { $C_NEW } else { $C_MERGE })

    set-chip ["drawing=on" $"label=($label)" $"label.color=($bcolor)" $"background.border_color=($bcolor)"]
}
