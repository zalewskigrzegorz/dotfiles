#!/usr/bin/env nu

# pr-watch — poll GitHub for actionable PRs of mine, push state to the SketchyBar
# `pr_watch` chip. Run by launchd every 3 min (com.greg.pr-watch). PUSH-driven:
# ends with `sketchybar --set`.
#
# "Actionable" mirrors bin/prs action logic — a PR needs MY action when it is
# ready to MERGE, has CHANGES_REQUESTED, or has failing CI ("fix CI"). PRs that
# wait on others (needs review / draft / blocked) are NOT actionable → chip's
# fix/merge counters stay hidden for them.
#
# Outstanding comments: for EVERY open PR (not just actionable), we count
# comments that still need MY attention — computed LIVE each poll (no delta), so
# the cyan chip PERSISTS until I deal with them and never silently disappears.
# A comment is "outstanding" when it is neither RESOLVED nor ANSWERED:
#   * unresolved review thread whose last comment is NOT mine (and not a bot)
#   * conversation comment by someone else that I haven't replied to since
# Bots and my own comments never count. The count drops on the next poll (≤3 min)
# as soon as I resolve a thread or reply — self-clearing, no manual ack.
#
# Cache: ~/.cache/pr-watch-last.json  { "<num>": {action, outstanding, actionable, title, url} }
# (cache is only a fallback for transient gh/GraphQL failures — the flag is live.)

const REPO = "REDACTED_ORG/REDACTED_ORG"
const FIELDS = "number,title,isDraft,reviewDecision,mergeable,statusCheckRollup,headRefName,url"
# My GitHub login — comments by me never count as "new" (self-clear on reply).
const ME = "zalewskigrzegorz"

# Nerd Font glyphs — picked to be self-explanatory AND visually distinct from each
# other (the two git octicons looked alike at chip size).
const G_FIX = "\u{f0ad}"     # wrench   — changes req / fix CI (needs your fix)
const G_MERGE = "\u{f00c}"   # check    — ready to merge
const G_COMMENT = "\u{f075}" # comment  — new unresolved thread since last poll
const G_RUN = "\u{f017}"     # clock    — CI run in progress (e2e / pipeline)

# State colors — dynamic. Mirror docs/mocha-neon-palette.md.
const C_FIX = "0xffff8c42"   # peach — needs your fix (urgent, but not agents' red)
const C_MERGE = "0xff50fa7b" # green — ready to merge
const C_NEW = "0xff8be9fd"   # sky   — new comment
const C_RUN = "0xffffd700"   # gold  — CI in progress

def set-chip [args: list<string>] {
    if (which sketchybar | is-not-empty) {
        ^sketchybar --set pr_watch ...$args | ignore
    }
}

# Helper: is this comment author someone OTHER than me and not a bot?
def is-foreign [c: any]: nothing -> bool {
    let login = ($c | get -o author.login | default "")
    let typ = ($c | get -o author.__typename | default "")
    ($typ != "Bot") and ($login != $ME) and ($login != "github-actions")
}

# Count comments on a PR still needing MY attention (unresolved-and-not-mine
# review threads + conversation comments I haven't replied to since). Only
# reachable via GraphQL (gh pr view --json has no reviewThreads field). Returns
# null on failure so the caller keeps the cached count.
def outstanding-comments [num: int]: nothing -> any {
    let parts = ($REPO | split row "/")
    let q = 'query($owner:String!,$name:String!,$num:Int!){repository(owner:$owner,name:$name){pullRequest(number:$num){reviewThreads(first:100){nodes{isResolved comments(last:1){nodes{author{login __typename}}}}} comments(last:30){nodes{createdAt author{login __typename}}}}}}'
    let r = (do {
        ^gh api graphql -f $"query=($q)" -F $"owner=($parts.0)" -F $"name=($parts.1)" -F $"num=($num)"
    } | complete)
    if $r.exit_code != 0 { return null }
    let pr = ($r.stdout | from json | get -o data.repository.pullRequest | default {})

    # Review threads: unresolved AND whose last comment is foreign (I haven't
    # answered or resolved it).
    let threads_out = ($pr | get -o reviewThreads.nodes | default [] | where {|t|
        let resolved = ($t | get -o isResolved | default false)
        let last = ($t | get -o comments.nodes | default [] | last)
        (not $resolved) and (is-foreign $last)
    } | length)

    # Conversation: outstanding if the newest foreign comment is later than my
    # newest comment (i.e. someone spoke last and I haven't replied).
    let conv = ($pr | get -o comments.nodes | default [])
    let mine_ts = ($conv | where {|c| ($c | get -o author.login | default "") == $ME} | get -o createdAt | default [])
    let my_latest = (if ($mine_ts | is-empty) { "" } else { $mine_ts | sort | last })
    let foreign_ts = ($conv | where {|c| is-foreign $c} | get -o createdAt | default [])
    let foreign_latest = (if ($foreign_ts | is-empty) { "" } else { $foreign_ts | sort | last })
    let conv_out = (($foreign_latest != "") and ($foreign_latest > $my_latest))

    # unresolved_any: ALL unresolved threads (even where I spoke last) — GitHub
    # blocks merging on any unresolved conversation, regardless of last author.
    let unresolved_any = ($pr | get -o reviewThreads.nodes | default [] | where {|t|
        not ($t | get -o isResolved | default false)
    } | length)

    { out: ($threads_out + (if $conv_out { 1 } else { 0 })), unresolved: $unresolved_any }
}

def main [] {
    let cache_path = ($env.HOME | path join ".cache" "pr-watch-last.json")
    let prev = (if ($cache_path | path exists) {
        (try { open $cache_path } catch { {} })
    } else { {} })

    let listed = (do { ^gh pr list --author "@me" --repo $REPO --state open --json $FIELDS --limit 30 } | complete)
    if $listed.exit_code != 0 {
        # gh failed (offline / auth) → leave the chip untouched, try again next poll.
        exit 0
    }
    let prs = ($listed.stdout | from json)

    let rows = ($prs | each { |pr|
        let failed = ($pr.statusCheckRollup | where {|c| ($c | get -o conclusion) == "FAILURE"} | length)
        # Still-running/expected checks: CheckRun has status (COMPLETED/IN_PROGRESS/
        # QUEUED), StatusContext has state (PENDING/EXPECTED/...). Either kind
        # unfinished → the PR is NOT mergeable yet, whatever GitHub's mergeable says.
        let pending = ($pr.statusCheckRollup | where {|c|
            let st = ($c | get -o status | default "")
            let state = ($c | get -o state | default "")
            (($st != "") and ($st != "COMPLETED")) or ($state in ["PENDING" "EXPECTED"])
        } | length)
        # e2e never started: a required StatusContext sits EXPECTED ("waiting for
        # status to be reported") while no e2e CheckRun is actually running —
        # happens when "E2E tests: skip by label" skipped. Fix = run_e2e toggle.
        let e2e_expected = ($pr.statusCheckRollup | where {|c| ($c | get -o state | default "") == "EXPECTED"} | length)
        let e2e_running = ($pr.statusCheckRollup | where {|c|
            let st = ($c | get -o status | default "")
            (($st != "") and ($st != "COMPLETED")) and (($c | get -o name | default "") =~ "(?i)e2e")
        } | length)
        let review = ($pr | get -o reviewDecision | default "")
        let draft = $pr.isDraft
        let action = (
            if $draft and $failed > 0            { "draft+CI" }
            else if $draft                       { "draft" }
            else if $failed > 0                  { "fix CI" }
            else if $pr.mergeable == "CONFLICTING" { "conflict" }
            else if $review == "CHANGES_REQUESTED" { "changes req" }
            else if $review == "REVIEW_REQUIRED"   { "needs review" }
            else if ($e2e_expected > 0) and ($e2e_running == 0) { "run e2e" }
            else if $pending > 0                   { "CI…" }
            else if $pr.mergeable == "MERGEABLE"   { "MERGE" }
            else                                    { "blocked" }
        )
        let actionable = ($action in ["MERGE" "changes req" "fix CI" "conflict" "run e2e"])
        {number: $pr.number, action: $action, title: $pr.title, url: $pr.url, actionable: $actionable}
    })

    # Outstanding-comment count — EVERY open PR (one GraphQL each, ~7 calls /
    # 3 min poll). Computed live; cache is only a fallback on GraphQL failure.
    let enriched = ($rows | each { |r|
        let key = ($r.number | into string)
        let prev_out = ($prev | get -o $key | get -o outstanding | default 0)
        let prev_unres = ($prev | get -o $key | get -o unresolved | default 0)
        let cur = (outstanding-comments $r.number)
        let out = (if $cur == null { $prev_out } else { $cur.out })
        let unres = (if $cur == null { $prev_unres } else { $cur.unresolved })
        # GitHub blocks merge on ANY unresolved conversation → never claim MERGE
        # while threads are open; my action is to resolve them.
        let action = (if ($r.action == "MERGE") and ($unres > 0) { "resolve" } else { $r.action })
        $r | merge { action: $action, actionable: ($r.actionable or ($action == "resolve")), outstanding: $out, unresolved: $unres }
    })

    # Persist cache (fallback for transient gh/GraphQL failures).
    let cache = ($enriched | reduce -f {} { |r, acc|
        $acc | insert ($r.number | into string) {
            action: $r.action, outstanding: $r.outstanding, unresolved: $r.unresolved, actionable: $r.actionable, title: $r.title, url: $r.url
        }
    })
    mkdir ($cache_path | path dirname)
    $cache | to json | save -f $cache_path

    # Outstanding comments surface on ANY PR; fix/merge counters only from
    # actionable PRs. n_comments = total comments still awaiting my reply/resolve.
    let act = ($enriched | where actionable)
    let n_comments = ($enriched | get outstanding | math sum)
    let n_run = ($enriched | where action == "CI…" | length)
    if ($act | is-empty) and ($n_comments == 0) and ($n_run == 0) {
        set-chip ["drawing=off"]
        return
    }

    let n_fix = ($act | where action in ["fix CI" "changes req" "conflict" "run e2e"] | length)
    let n_merge = ($act | where action == "MERGE" | length)

    mut parts = []
    if $n_fix > 0   { $parts = ($parts | append $"($G_FIX) ($n_fix)") }
    if $n_merge > 0 { $parts = ($parts | append $"($G_MERGE) ($n_merge)") }
    if $n_comments > 0 { $parts = ($parts | append $"($G_COMMENT) ($n_comments)") }
    if $n_run > 0   { $parts = ($parts | append $"($G_RUN) ($n_run)") }
    let label = ($parts | str join "   ")

    # Urgency color drives BOTH border and label text (single label can't color
    # per-segment): peach (needs fix) > sky (unanswered comment) > gold (CI
    # running) > green (merge).
    let bcolor = (if $n_fix > 0 { $C_FIX } else if $n_comments > 0 { $C_NEW } else if $n_run > 0 { $C_RUN } else { $C_MERGE })

    set-chip ["drawing=on" $"label=($label)" $"label.color=($bcolor)" $"background.border_color=($bcolor)"]
}
