#!/usr/bin/env nu

# Wrapper for the private Slack-board weekly update script.
# - resolves the script path (env override → secrets dir)
# - if --since isn't passed, interactively prompts with a sensible default
#   (previous Monday strictly before today)
# - forwards all args to the nu script

def main [
    --since: string = ""
    --until: string = ""
    --output (-o): string = ""
] {
    let secret_dir = ($env.DOTFILES_SECRET_DIR? | default $"($env.HOME)/.local/state/dotfiles/secrets")
    let script = ($env.DOTFILES_WEEKLY_PROJECT_UPDATE_SCRIPT? | default $"($secret_dir)/weekly-slack-board-update.nu")

    if not ($script | path exists) {
        print -e $"Weekly project update script was not found:\n  ($script)\n\nSet DOTFILES_WEEKLY_PROJECT_UPDATE_SCRIPT or restore the local secret file."
        exit 1
    }

    let resolved_since = if ($since | is-empty) {
        # Default: previous Monday strictly before today (Mon = %u 1 .. Sun = 7).
        let dow = (date now | format date "%u" | into int)
        let days_back = if $dow == 1 { 7 } else { $dow - 1 }
        let default_since = (date now | $in - ($days_back * 1day) | format date "%Y-%m-%d")

        let typed = (input $"since \(YYYY-MM-DD\) [($default_since)]: ")
        let picked = (if ($typed | str trim | is-empty) { $default_since } else { $typed | str trim })

        if not ($picked =~ '^\d{4}-\d{2}-\d{2}$') {
            print -e $"error: expected YYYY-MM-DD, got '($picked)'"
            exit 2
        }
        print $"→ --since ($picked)"
        $picked
    } else {
        $since
    }

    mut extra: list<string> = []
    if not ($until | is-empty)  { $extra = ($extra | append ["--until" $until]) }
    if not ($output | is-empty) { $extra = ($extra | append ["--output" $output]) }

    nu $script --since $resolved_since ...$extra
}
