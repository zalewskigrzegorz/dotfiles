#!/usr/bin/env bash
# Per-window presence glyph for tmux window-status formats. Fork-cheap: reads one
# state file + the window name arg, no tmux/git.
# Usage: claude-agent-badge <session> <window> [window_name]
#   blocked (nf-fa-warning) waiting (nf-fa-clock_o) running (nf-fa-circle)
# Single-width nerd-font glyphs (NOT emoji): emoji are double-width and throw off
# tmux's clickable window-range maths in the status bar.
# Fallback: if no state file but the window NAME carries the claude glyph
# (U+F06A9), show the waiting glyph — a claude window with no hook event yet
# (started before the hooks, or idle since) would otherwise be invisible.
set -u
G_BLOCKED=$'\uf071'   # nf-fa-warning
G_WAITING=$'\uf017'   # nf-fa-clock_o
G_RUNNING=$'\uf111'   # nf-fa-circle
DIR="${CLAUDE_AGENT_STATE_DIR:-/tmp/claude-agents}"
[ $# -ge 2 ] || exit 0
target="$1:$2"
name="${3:-}"
f="$DIR/$(printf '%s' "$target" | tr -c 'A-Za-z0-9._-' '_')"

if [ -f "$f" ]; then
  case "$(sed -n 's/^state=//p' "$f")" in
    blocked) printf ' %s' "$G_BLOCKED" ;;
    waiting) printf ' %s' "$G_WAITING" ;;
    running) printf ' %s' "$G_RUNNING" ;;
  esac
  exit 0
fi

# No state file -> fallback for claude windows (name carries the claude glyph).
case "$name" in *$'\U000F06A9'*) printf ' %s' "$G_WAITING" ;; esac
exit 0
