#!/usr/bin/env bash
# Refresh the sketchybar claude_agents chip from agent state. PUSH-driven: called
# by the agent hooks (on every state change) and a tmux window-switch hook — NOT
# sbarlua's routine timer, which never fired for this item. Label:
#    <blocked>  <waiting>  <running>   (counts EXCLUDE the current tmux window —
# the chip means "agents needing you ELSEWHERE", matching the cmd-ctrl-w jump).
set -u
# launchd (AeroSpace/sketchybar) starts us with no locale → C, which breaks
# bash read/assoc-array on multibyte session names (emoji). Force UTF-8.
export LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
export PATH="/opt/homebrew/bin:$PATH"
command -v sketchybar >/dev/null 2>&1 || exit 0
STATE="$HOME/Code/dotfiles/bin/claude-agent-state"
G_BLOCKED=$'\uf071'; G_WAITING=$'\uf017'; G_RUNNING=$'\uf111'

CUR=$(tmux display-message -p '#{session_name}:#{window_index}' 2>/dev/null || true)
# Command-substitution + here-string (NOT `done < <(...)`): process substitution
# yields nothing in some non-interactive contexts.
LIST=$("$STATE" list 2>/dev/null || true)
b=0; w=0; r=0
while IFS=$'\t' read -r st tg _; do
  [ -z "$st" ] && continue
  [ -n "$CUR" ] && [ "$tg" = "$CUR" ] && continue
  case "$st" in blocked) b=$((b + 1)) ;; waiting) w=$((w + 1)) ;; running) r=$((r + 1)) ;; esac
done <<< "$LIST"

label=""
[ "$b" -gt 0 ] && label="${G_BLOCKED} $b"
[ "$w" -gt 0 ] && label="${label:+$label   }${G_WAITING} $w"
[ "$r" -gt 0 ] && label="${label:+$label   }${G_RUNNING} $r"

if [ -n "$label" ]; then
  # Border accent by dominant state (urgency order): blocked=red, waiting=gold,
  # running=mauve (primary). Must mirror colors.lua hex values.
  if [ "$b" -gt 0 ]; then bcolor=0xffff6b9d        # red    — needs you
  elif [ "$w" -gt 0 ]; then bcolor=0xffffd700      # gold   — waiting
  else bcolor=0xffb347ff; fi                       # mauve  — running (primary)
  sketchybar --set claude_agents drawing=on label="$label" background.border_color="$bcolor" >/dev/null 2>&1 || true
else
  sketchybar --set claude_agents drawing=off >/dev/null 2>&1 || true
fi
