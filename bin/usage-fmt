#!/usr/bin/env bash
# ~/Code/dotfiles/bin/usage-fmt
# Print human-readable consumed-tokens for the current Claude session block
# or the current week. Reads from ccusage cache (no network).
# Output examples: "73.2M", "1.7G", "428K", "?" if unavailable
#
# Shares cache files with usage-pct (claude-usage-{blocks,weekly}-${uid}.txt)
# so any hot-path caller (tmux, future status segments) reuses the same data.
set -euo pipefail

WINDOW="${1:-}"
CACHE_TTL_SECS=30
uid="${UID:-$(id -u)}"
cache_dir="${TMPDIR:-/tmp}"

fmt_count() {
  local n="${1:-0}"
  [[ -z "$n" || "$n" == "null" ]] && { echo "?"; return; }
  awk -v n="$n" '
    BEGIN {
      if (n >= 1e9)      printf "%.1fG", n / 1e9
      else if (n >= 1e6) printf "%.1fM", n / 1e6
      else if (n >= 1e3) printf "%.0fK", n / 1e3
      else               printf "%d", n
    }
  '
}

fetch_used() {
  local kind="$1"
  local cmd="$2"
  local jq_path="$3"
  local cache_file="$cache_dir/claude-usage-${kind}-${uid}.txt"
  local now age
  now=$(date +%s)
  if [[ -f "$cache_file" ]]; then
    age=$(( now - $(stat -f %m "$cache_file" 2>/dev/null || echo 0) ))
    if (( age < CACHE_TTL_SECS )); then
      cat "$cache_file"
      return
    fi
  fi
  local fresh
  fresh=$(ccusage $cmd 2>/dev/null | jq "$jq_path" 2>/dev/null || echo 0)
  [[ -z "$fresh" || "$fresh" == "null" ]] && fresh=0
  printf '%s' "$fresh" > "$cache_file" 2>/dev/null || true
  printf '%s' "$fresh"
}

case "$WINDOW" in
  session)
    USED=$(fetch_used "blocks" "blocks --json --active --offline" '.blocks[0].totalTokens // 0')
    ;;
  week)
    USED=$(fetch_used "weekly" "weekly --json --offline" '.weekly[-1].totalTokens // 0')
    ;;
  *)
    echo "usage: usage-fmt <session|week>" >&2
    exit 2
    ;;
esac

fmt_count "$USED"
