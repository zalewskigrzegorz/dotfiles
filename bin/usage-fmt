#!/usr/bin/env bash
# ~/Code/dotfiles/bin/usage-fmt
# Print human-readable consumed-tokens for the current Claude session block
# or the current week. Reads from ccusage cache (no network).
# Output examples: "73.2M", "1.7G", "428K", "?" if unavailable
set -euo pipefail

WINDOW="${1:-}"

fmt_count() {
  local n="${1:-0}"
  [[ -z "$n" || "$n" == "null" ]] && { echo "?"; return; }
  awk -v n="$n" '
    BEGIN {
      if (n >= 1e9)      printf "%.1fG", n / 1e9
      else if (n >= 1e6) printf "%.1fM", n / 1e6
      else if (n >= 1e3) printf "%.0fK", n / 1e3
      else               printf "%d", n
    }
  '
}

case "$WINDOW" in
  session)
    USED=$(ccusage blocks --json --active --offline 2>/dev/null \
      | jq '.blocks[0].totalTokens // 0' 2>/dev/null || echo 0)
    ;;
  week)
    USED=$(ccusage weekly --json --offline 2>/dev/null \
      | jq '.weekly[-1].totalTokens // 0' 2>/dev/null || echo 0)
    ;;
  *)
    echo "usage: usage-fmt <session|week>" >&2
    exit 2
    ;;
esac

fmt_count "$USED"
