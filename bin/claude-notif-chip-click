#!/usr/bin/env bash
# Click handler for the sketchybar notif_preview chip.
# If the chip currently shows a Claude-waiting banner (title contains the "▸"
# marker we put in `notify-waiting.sh`), switch tmux to the waiting session
# instead of opening the sender app. For every other notification (Slack,
# Spark, Calendar, …) fall back to `open -b <bundle>` so the source app is
# raised as before. Called with the bundle id as $1.
set -u
SBAR="${SKETCHYBAR:-/opt/homebrew/bin/sketchybar}"
JQ="${JQ:-/opt/homebrew/bin/jq}"
OPEN="${OPEN_BIN:-/usr/bin/open}"
FOCUS="${CLAUDE_FOCUS_SESSION:-/Users/greg/Code/dotfiles/bin/claude-focus-session}"
SESSIONS="${CLAUDE_SESSIONS:-/Users/greg/Code/dotfiles/bin/claude-sessions}"

label=$("$SBAR" --query notif_preview 2>/dev/null | "$JQ" -r '.label.value // ""')

case "$label" in
  *▸*)
    sess=$("$SESSIONS" --json 2>/dev/null | "$JQ" -r '[.[] | select(.waiting)] | .[0].tmux_session // empty')
    "$FOCUS" "$sess"
    ;;
  *)
    bundle="${1:-}"
    [ -n "$bundle" ] && "$OPEN" -b "$bundle" >/dev/null 2>&1 || true
    ;;
esac
exit 0
