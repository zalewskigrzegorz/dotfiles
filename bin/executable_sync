#!/usr/bin/env bash
set -euo pipefail

brew_bins=(
  /home/linuxbrew/.linuxbrew/bin
  "${HOME}/.linuxbrew/bin"
  /opt/homebrew/bin
  /usr/local/bin
  "${HOME}/.local/bin"
)

for d in "${brew_bins[@]}"; do
  if [[ -d "$d" ]]; then
    PATH="$d:$PATH"
  fi
done
export PATH

if ! command -v chezmoi >/dev/null 2>&1; then
  echo "chezmoi not found on PATH. Install it first, then run sync again." >&2
  exit 127
fi

exec chezmoi apply "$@"
