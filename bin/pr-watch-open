#!/usr/bin/env bash
# pr-watch-open — click handler for the SketchyBar pr_watch chip.
#
# Opens gh-dash (my Redocly PRs) in a herdr workspace and focuses it; you take it
# from there. In gh-dash: `T` opens the selected PR in a worktree workspace (see
# dot_config/private_gh-dash/config.yml), or open it in the browser to merge.
#
# Reuses an existing gh-dash workspace if one is already open, else creates one
# running `gh dash`. No-ops cleanly if the herdr server isn't running.
set -uo pipefail
export PATH="/opt/homebrew/bin:$PATH"

HERDR_BIN="${HERDR_BIN:-/opt/homebrew/bin/herdr}"
REPO_DIR="${PR_WATCH_REPO_DIR:-$HOME/Code/Redocly/redocly}"
LABEL="${PR_WATCH_DASH_LABEL:-📋 gh-dash}"

command -v jq >/dev/null 2>&1 || exit 0
[ -x "$HERDR_BIN" ] || exit 0

# Reuse an open gh-dash workspace if present; otherwise create one running `gh dash`.
ws=$("$HERDR_BIN" workspace list 2>/dev/null \
  | jq -r --arg l "$LABEL" '.result.workspaces[]? | select(.label==$l) | .workspace_id' 2>/dev/null \
  | head -1)

if [ -n "$ws" ]; then
  "$HERDR_BIN" workspace focus "$ws" >/dev/null 2>&1 || true
else
  out=$("$HERDR_BIN" workspace create --cwd "$REPO_DIR" --label "$LABEL" --focus 2>/dev/null || true)
  pane=$(printf '%s' "$out" | jq -r '.result.root_pane.pane_id // empty' 2>/dev/null)
  [ -n "$pane" ] && "$HERDR_BIN" pane run "$pane" "gh dash" >/dev/null 2>&1 || true
fi
