#!/usr/bin/env bash
# ~/Code/dotfiles/bin/claude-watcher
# Watch ~/.claude/projects/ for .jsonl changes.
# On each change: invalidate claude-sessions cache + trigger sketchybar event (mac).
# Designed to run as a LaunchAgent (mac) or systemd user service (lab).
set -euo pipefail

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
CACHE_FILE="${CLAUDE_SESSIONS_CACHE:-/tmp/claude-sessions-$(id -u).json}"

is_mac() { [[ "$(uname -s)" == "Darwin" ]]; }

invalidate_and_notify() {
  rm -f "$CACHE_FILE"
  "$(dirname "${BASH_SOURCE[0]}")/claude-sessions-render" 2>/dev/null || true
  # One-line trace so `tail -f /tmp/com.greg.claude-watcher.log` shows activity
  # — without this the log stays empty and the user can't tell if it's working.
  printf '%s [trigger] jsonl change → cache invalidated + render re-fired\n' \
    "$(date '+%F %T')"
}

watch_mac() {
  command -v fswatch >/dev/null || { echo "fswatch not installed (brew install fswatch)" >&2; exit 1; }
  # -0    NUL-delimited records
  # -r    recursive (default with directories but explicit for clarity)
  # -e ".*"    exclude all by default
  # -i "\\.jsonl$"  re-include .jsonl files
  fswatch -0 -r -e ".*" -i "\\.jsonl$" "$PROJECTS_DIR" \
    | while IFS= read -r -d '' _; do
        invalidate_and_notify
      done
}

watch_linux() {
  command -v inotifywait >/dev/null || { echo "inotifywait not installed (apt install inotify-tools)" >&2; exit 1; }
  inotifywait -m -r -e modify -e create -e moved_to --format '%w%f' "$PROJECTS_DIR" \
    | while read -r path; do
        case "$path" in
          *.jsonl) invalidate_and_notify ;;
        esac
      done
}

# Ensure the directory exists so fswatch doesn't error out on first run.
mkdir -p "$PROJECTS_DIR"

if is_mac; then watch_mac; else watch_linux; fi
