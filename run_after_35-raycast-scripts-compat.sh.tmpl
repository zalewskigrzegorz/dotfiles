#!/usr/bin/env bash
set -euo pipefail

# Raycast reads script commands from $old_labs_shortcuts_dir (registered via
# `defaults write com.raycast.macos scriptCommandsDirectories`). Mirror the
# chezmoi-managed scripts there as **symlinks** so any edit to the source in
# ~/.config/raycast/scripts/ propagates to Raycast without needing this hook to
# re-run. Copies (install -m 0755) caused stale-mirror bugs when the source
# was updated by a partial `chezmoi apply <file>`.
current_scripts_dir="$HOME/.config/raycast/scripts"
old_labs_shortcuts_dir="$HOME/Code/Labs/shortcuts"

link_script() {
  local target_dir="$1"
  local script="$2"
  local source="$current_scripts_dir/$script"
  local target="$target_dir/$script"

  [[ -f "$source" ]] || return 0

  mkdir -p "$target_dir"
  # -f replaces existing files/symlinks, -n stops ln from following a symlink
  # target dir (would otherwise create the link inside it).
  ln -sfn "$source" "$target"
}

if [[ -d "$current_scripts_dir" ]]; then
  for script in \
    clearGithubNotification.sh \
    create-new-branch.sh \
    resolve-email-alias.sh \
    restart-aerospace.sh \
    run-e2e-on-github.sh \
    send-to-wife.sh
  do
    link_script "$old_labs_shortcuts_dir" "$script"
  done

  if [[ "$(uname -s)" == "Darwin" ]]; then
    defaults write com.raycast.macos scriptCommandsDirectories -array \
      "$old_labs_shortcuts_dir"
  fi
fi

# Remove dead mirror copies (not registered with Raycast, leftover from earlier
# Stow-migration setup). Safe to delete: nothing reads from these paths.
rm -rf "$HOME/raycast/script-commands"
