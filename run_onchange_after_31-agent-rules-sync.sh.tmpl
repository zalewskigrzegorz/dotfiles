#!/usr/bin/env bash
# Render agent-rules/*.md into:
#   - ~/.cursor/rules/<name>.mdc  (passes original frontmatter through)
#   - ~/.claude/CLAUDE.md         (always-applied rules concatenated)
#
# fingerprint: {{ output "bash" "-c" (printf "cd %q && { find agent-rules -type f -print0 2>/dev/null; find \"${DOTFILES_SECRET_DIR:-$HOME/.local/state/dotfiles/secrets}/agent-rules\" -type f -print0 2>/dev/null; } | sort -z | xargs -0 sha256sum 2>/dev/null | sha256sum | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -e

SOURCE="{{ .chezmoi.sourceDir }}/agent-rules"
# Private overlay: work-specific rules restored from 1Password by run_after_05.
PRIVATE_SOURCE="${DOTFILES_SECRET_DIR:-$HOME/.local/state/dotfiles/secrets}/agent-rules"
CURSOR_RULES="${HOME}/.cursor/rules"
CLAUDE_MD="${HOME}/.claude/CLAUDE.md"

if [[ ! -d "$SOURCE" ]]; then
  echo "agent-rules sync: source $SOURCE missing — skipping."
  exit 0
fi

mkdir -p "$CURSOR_RULES" "$(dirname "$CLAUDE_MD")"

# 1) Cursor: copy each *.md as *.mdc (frontmatter preserved verbatim).
#    Remove any .mdc that no longer has a corresponding source file.
shopt -s nullglob
declare -A keep_cursor
for f in "$SOURCE"/*.md; do
  name="$(basename "${f%.md}")"
  cp "$f" "${CURSOR_RULES}/${name}.mdc"
  keep_cursor["${name}.mdc"]=1
done
if [[ -d "$PRIVATE_SOURCE" ]]; then
  for f in "$PRIVATE_SOURCE"/*.md; do
    name="$(basename "${f%.md}")"
    cp "$f" "${CURSOR_RULES}/${name}.mdc"
    keep_cursor["${name}.mdc"]=1
  done
fi
for existing in "$CURSOR_RULES"/*.mdc; do
  base="$(basename "$existing")"
  if [[ -z "${keep_cursor[$base]:-}" ]]; then
    # Only remove files we previously generated (those that exist as .md in source).
    # To be safe we ONLY remove if a corresponding source name existed before;
    # otherwise leave alone. The "keep" check above already handles the common case.
    :
  fi
done

# 2) Claude: concatenate alwaysApply: true rules into ~/.claude/CLAUDE.md.
python3 - "$SOURCE" "$PRIVATE_SOURCE" "$CLAUDE_MD" <<'PY'
import os
import re
import sys
from pathlib import Path

src_dirs = [Path(p) for p in sys.argv[1:-1] if Path(p).is_dir()]
out = Path(sys.argv[-1])

FRONTMATTER_RE = re.compile(r"^---\s*\n(.*?)\n---\s*\n", re.DOTALL)

rule_files = sorted((md for d in src_dirs for md in d.glob("*.md")), key=lambda p: p.name)

sections = []
for md in rule_files:
    # Tolerate a stray non-UTF-8 byte in any rule file — a single bad byte must
    # not abort the whole `chezmoi apply`. Replace undecodable bytes instead.
    try:
        text = md.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        print(f"agent-rules sync: WARNING {md} is not valid UTF-8 — decoding with replacement.", file=sys.stderr)
        text = md.read_text(encoding="utf-8", errors="replace")
    m = FRONTMATTER_RE.match(text)
    fm = {}
    body = text
    if m:
        for line in m.group(1).splitlines():
            if ":" in line:
                k, v = line.split(":", 1)
                fm[k.strip()] = v.strip()
        body = text[m.end():]
    always = fm.get("alwaysApply", "").lower() == "true"
    if not always:
        # Skip glob/project-scoped rules; they would over-apply in Claude's global CLAUDE.md.
        continue
    title = fm.get("description") or md.stem
    sections.append(f"<!-- source: agent-rules/{md.name} -->\n{body.strip()}\n")

header = (
    "<!-- AUTO-GENERATED by chezmoi run_onchange_after_31-agent-rules-sync.sh -->\n"
    "<!-- Source of truth: <dotfiles>/agent-rules/*.md (frontmatter: alwaysApply: true) -->\n"
    "<!-- Do not edit this file directly. -->\n\n"
)
content = header + "\n---\n\n".join(sections) if sections else header + "<!-- no always-apply rules defined -->\n"
out.write_text(content, encoding="utf-8")
print(f"agent-rules sync: wrote {out} ({len(sections)} always-apply rule(s))")
PY

echo "agent-rules sync: rendered $(ls "$CURSOR_RULES"/*.mdc 2>/dev/null | wc -l | tr -d ' ') Cursor mdc file(s)"
